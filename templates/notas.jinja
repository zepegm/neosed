            const nome = $(this).val().toLowerCase();
            const nome_final = nome.replace(/(^\w{1})|(\s+\w{1})/g, letra => letra.toUpperCase()).replaceAll("De ", 'de ').replaceAll("Da ", 'da ').replaceAll("Dos ", 'dos ');

            array = nome_final.split(" ");

            console.log(array[0]);

            $("#txt_nomeata").val(array[0]);

            $(this).val(nome_final);
