<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Grade Horária</title>
    <link href="{{ url_for('static', filename='bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">

    <!-- Custom styles for this template -->
    <link href="{{ url_for('static', filename='stylesheets/navbar-top-fixed.css') }}" rel="stylesheet">   
    <link href="{{ url_for('static', filename='font-awesome/css/fontawesome.min.css') }}" rel="stylesheet">
    <link href="{{ url_for('static', filename='font-awesome/css/brands.css') }}" rel="stylesheet">
    <link href="{{ url_for('static', filename='font-awesome/css/solid.css') }}" rel="stylesheet">
    <link href="{{ url_for('static', filename='datatable/datatables.min.css') }}" rel="stylesheet">
    <link rel="shortcut icon" type="image/png" href="{{ url_for('static', filename='images/icon_sed.png') }}">

    <style>
        table {
            border-collapse: collapse;
            width: 100%;
            text-align: center;
            table-layout: fixed;            
        }

        #myTable th, #myTable td {
            text-align: center;
            border: 1px solid black;
            height: 5vh;
        }
        
        .dragging {
            opacity: 0.1;
        }

        .drag_cell {
            cursor: move;
        }

        #myTable, #tb_grade {
            margin-top: 1vh;
        }

        .blue-primary {
            background-color: #007BFF;
            color: white;
        }

        .gray {
            background-color: #747474;
        }

        {% for item in css_disc %}
            .tb_{{item['disc']}} { background-color: {{item['cor']}}; color: black; }
        {% endfor %}

    </style>
</head>
  <body style="background-color: rgba(244, 244, 244);">

    {% block menu_superior %}
      {% include 'menu.jinja' %}
    {% endblock %}  

    <!-- Modal -->
    <div class="modal fade" id="confirmar_edicao_modal" tabindex="-1" aria-labelledby="confirmar_edicao_modalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="confirmar_edicao_modalLabel">Habilitar Edição</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body">
                    <div class="row">
                        <div id="feedback" class="col-sm-12"></div>
                    </div>

                    <div class="row">
                        <div class="col-sm-12">
                            <label for="txtnumeroclasse">Senha</label>
                            <input type="password" class="form-control" id="txt_senha">               
                        </div>
                    </div>
                </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn btn-primary" id="btn_habilitar_edicao_confirm">Confirmar</button>
                        <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
                    </div>
            </div>
        </div>
    </div>

    <form action="/grade" method="post" enctype="multipart/form-data">
    <div class="modal fade" id="importar_planilha_urania" tabindex="-1" aria-labelledby="importar_planilha_uraniaLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="importar_planilha_uraniaLabel">Importar Planilha do Urânia</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body">
                    <input type="file" class="form-control" id="txt_planilha_urania" name="file" accept=".xlsx, .xls, .csv" required>
                    <input type="hidden" class="form-control" id="txt_num_classe" name="num_classe_import" required>
                </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="input" class="btn btn-primary" id="btn_habilitar_edicao_confirm">Confirmar</button>
                        <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
                    </div>
            </div>
        </div>
    </div> 
    </form>   


    <main class="container-xxl">
        <form id="form_ano" action="/grade" method="post">
            <div class="row mb-3">
                <div class="col-sm-2">
                    <div class="form-inline">
                        <div class="form-group">
                            <div class="input-group">            
                                <div class="input-group-text">Ano:</div>
                                <select class="form-select" id="cb_ano" name="ano">
                                    {% for ano in anos %}
                                    <option value="{{ano['ano']}}" {{ano['selected']}}>{{ano['ano']}}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-10">
                    <div class="form-inline">
                        <div class="form-group">
                            <div class="input-group">            
                                <div class="input-group-text">Ensino:</div>
                                <select class="form-select" id="cb_ensino" name="ano">
                                    <option value="(1)">PEI - Fundamental</option>
                                    <option value="(3, 4)">PEI - Médio + Técnico</option>
                                </select>
                                <div class="input-group-text">Estilo:</div>
                                <select class="form-select" id="cb_estilo" name="ano">
                                    <option value="grade">Compacto com Disciplinas coloridas por professor</option>
                                    <option value="grade_alt">Espaçado com disciplinas coloridas por dia da semana</option>
                                    <option value="individual">Horário Individual dos Professores</option>
                                </select> 
                                <div class="input-group-text">Data:</div>
                                <input type="date" class="form-control" id="txt_data" value="{{data}}">
                                <button id="btn-gerar-horario" class="btn btn-danger">Gerar PDF</button>                              
                            </div>
                        </div>
                    </div>                
                </div>

            </div>
        </form>

        <div class="row">
            <div class="col-sm-3">
                <div id="lista_geral" class="list-group">
                    {% for turma in turmas %}
                    <a data-duracao="{{turma['duracao']}}" href="#" class="list-group-item list-group-item-action" data-id="{{turma['num_classe']}}">
                        {{turma['nome_turma']}} - {{turma['duracao']}}
                    </a>
                    {% endfor %}
                </div>
            </div>

            <div id="painel_Grade" class="col-sm-9">
                <div id="status">{{msg}}</div>
            </div>
        </div>

        <form id="form_limpar" action="/grade" method="post">
            <input type="hidden" id="num_classe" name="num_classe" value="">
        </form>

        <form id="form_importar_sed" action="/grade" method="post" enctype="multipart/form-data">
            <input type="hidden" id="num_classe_import_sed" name="num_classe_import_sed" value="">
        </form>
    </main>

