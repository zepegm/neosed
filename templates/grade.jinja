    <script src="{{ url_for('static', filename='js/jquery-3.7.0.min.js') }}"></script> 
    <!-- <script src="{{ url_for('static', filename='js/jquery.mask.min.js') }}"></script> -->
    <script src="{{ url_for('static', filename='bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ url_for('static', filename='datatable/datatables.min.js') }}"></script>
    <script src="{{ url_for('static', filename='jspdf/jspdf.umd.min.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/BebasKai-normal.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/GreatVibes-Regular-normal.js') }}"></script>  
    <script src="{{ url_for('static', filename='js/gerador-pdf.js') }}"></script>
    <script src="{{ url_for('static', filename='bootstrap-multiselect/popper.js') }}"></script>
    <script src="{{ url_for('static', filename='bootstrap-multiselect/bootstrap-multiselect.js') }}"></script>

    <script>

        const semanas_dias = ['Seg', 'Ter', 'Qua', 'Qui', 'Sex'];

        function addDrag(name_table) {
            const table = document.getElementById(name_table);
            let draggedCell = null;

            table.addEventListener('dragstart', (event) => {
                draggedCell = event.target;
                event.target.classList.add('dragging');
            });

            table.addEventListener('dragend', (event) => {
                event.target.classList.remove('dragging');
            });

            table.addEventListener('dragover', (event) => {
                event.preventDefault();
            });

            table.addEventListener('drop', (event) => {
                event.preventDefault();
                if (event.target.tagName === 'TD' && event.target !== draggedCell) {
                    const draggedHTML = draggedCell.innerHTML;
                    const draggedClass = draggedCell.className;
                    const draggedDataId = draggedCell.getAttribute('data-id');
                    const draggedStatus = draggedCell.getAttribute('draggable');

                    draggedCell.innerHTML = event.target.innerHTML;
                    draggedCell.className = event.target.className;
                    draggedCell.setAttribute('data-id', event.target.getAttribute('data-id'));
                    draggedCell.setAttribute('draggable', event.target.getAttribute('draggable'));

                    event.target.innerHTML = draggedHTML;
                    event.target.className = draggedClass;
                    event.target.setAttribute('data-id', draggedDataId);
                    event.target.setAttribute('draggable', draggedStatus);

                    // Remove the dragging class from the dragged cell
                    event.target.classList.remove('dragging');
                }
            });
        }

        $("#btn-gerar-horario").on('click', function() {

            $("#btn-gerar-horario").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btn-gerar-horario").attr('disabled', '');

            let ano = $("#cb_ano").val();
            let ensino = $("#cb_ensino").val();
            let estilo = $("#cb_estilo").val();
            let data = $("#txt_data").val();

            let dataParts = data.split("-");
            let dataFormatada = `${dataParts[2]}/${dataParts[1]}/${dataParts[0]}`;

            info = {'destino':15, 'ano':ano, 'ensino':ensino, 'estilo':estilo, 'data':dataFormatada};

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btn-gerar-horario").html('Exportar PDF');
                $("#btn-gerar-horario").removeAttr('disabled');
                },
            });            
        });

        $("#cb_ano").change(function() {
            $("#form_ano").submit();
        });

        $(".list-group").on('click', 'a', function() {

            $("#painel_Grade").empty();
            $("#painel_Grade").append('<div id="status"></div>');

            $(this).addClass('active').siblings().removeClass('active');
            var num_classe = $(this).attr('data-id');
            
            $.ajax({
                type: "POST",
                url: "grade",
                contentType: "application/json",
                data: JSON.stringify(num_classe),
                dataType: "json",
                success: function(data) {

                    var cont_cols = 0;

                    $("#painel_Grade").append('<b>Aulas Disponíveis:</b>');
                    
                    html = '<table id="myTable">';
                    html += '<tbody>';
                    html += '<tr>';

                    $.each(data['matriz'], function(index, value) {
                        for (let i = 0; i < value['qtd_aulas']; i++) {
                            html += `<td draggable="true" class='tb_${value['disc']} drag_cell' data-id='${value['disc']}'>${value['abv']}</td>`;

                            cont_cols++;

                            if (cont_cols == 6) {
                                html += '</tr>';
                                html += '<tr>';
                                cont_cols = 0;
                            }                            
                        }

                    });

                    html += '</tr>';
                    html += '</tbody>';
                    html += '</table>';

                    $("#painel_Grade").append(html);

                    // adicionar outra tabela
                    $("#myTable").append('<tbody><tr><th class="fw-bold" colspan="5" style="text-align:left;border:none;">Grade Atual:</th></tr></tbody>');

                    grade_html = '<tbody>';
                    grade_html += '<tr>';
                    grade_html += '<th class="blue-primary">Horário</th>';
                    grade_html += '<th class="blue-primary">Seg</th>';
                    grade_html += '<th class="blue-primary">Ter</th>';
                    grade_html += '<th class="blue-primary">Qua</th>';
                    grade_html += '<th class="blue-primary">Qui</th>';
                    grade_html += '<th class="blue-primary">Sex</th>';
                    grade_html += '</tr>';
                    grade_html += '</tbody>';
                    grade_html += '<tbody id="tbody_grade"></tbody>';

                    $("#myTable").append(grade_html);

                    qtd_linhas = data['qtd_linhas'];

                    cont_disc = 0;

                    for (let i = 0; i < qtd_linhas; i++) {
                        if (data['grade'].length > i) {
                            var html = `<tr><th draggable="false">${data['horario'][i]}</th>`;
                            
                            for (let j = 0; j < 5; j++) {
                                console.log(data['grade'][cont_disc]);
                                if (data['grade'][cont_disc]['disciplina'] != null) {
                                    html += `<td class="tb_${data['grade'][cont_disc]['disciplina']}" data-id="${data['grade'][cont_disc]['disciplina']}" draggable="true">${data['grade'][cont_disc]['abv']}</td>`;
                                } else {
                                    html += `<td class="gray" draggable="false"></td>`;
                                }
                                cont_disc++;
                            }


                            html += '</tr>'
                            $("#tbody_grade").append(html);
                        } else {
                            $("#tbody_grade").append(`<tr><th draggable="false">${data['horario'][i]}</th><td class="gray" draggable="false"></td><td class="gray" draggable="false"></td><td class="gray" draggable="false"></td><td class="gray" draggable="false"></td><td class="gray" draggable="false"></td></tr>`);
                        }
                    }

                    $("#painel_Grade").append('<button id="btn_habilitar_edicao" class="btn btn-secondary mt-3" data-bs-toggle="modal" data-bs-target="#confirmar_edicao_modal">Habilitar Edição</button>');
                    /*$("#painel_Grade").append('<button id="btn_salvar" class="mt-3 btn btn-primary">Salvar</button>&nbsp;');
                    $("#painel_Grade").append('<button id="btn_limpar" class="mt-3 btn btn-secondary">Limpar Grade</button>');*/

                    addDrag('myTable');
                },
            });              
        });

        $(document).on('click', '#btn_limpar', function() {
            var num_classe = $(".list-group-item.active").attr('data-id');

            $("#num_classe").val(num_classe);
            $("#form_limpar").submit();
        });

        $(document).on('click', '#btn_importar_sed', function() {
            var num_classe = $(".list-group-item.active").attr('data-id');

            $("#num_classe_import_sed").val(num_classe);
            $("#form_importar_sed").submit();
        });        

        $(document).on('click', '#btn_salvar', function() {
            var horarios = [];
            var disciplinas = [];

            $("#tbody_grade tr").each(function() {
                var dia = {};

                var pos_sem = 0;

                $(this).find('td').each(function() {

                    let disc = $(this).attr('data-id');

                    if (disc == undefined) {
                        disc = 'null';
                    }

                    dia[semanas_dias[pos_sem]] = disc;

                    pos_sem++;
                });

                disciplinas.push(dia);
            });

            var num_classe = $(".list-group-item.active").attr('data-id');

            $.ajax({
                type: "POST",
                url: "salvar_grade",
                contentType: "application/json",
                data: JSON.stringify({num_classe: num_classe, disciplinas: disciplinas}),
                dataType: "json",
                success: function(data) {
                    $("#status").html(data['msg']);
                },
            });
        });

        $("#btn_habilitar_edicao_confirm").on('click', function() {
            let senha = $("#txt_senha").val();
            $.ajax({
                type: "POST",
                url: "confirmar_senha",
                contentType: "application/json",
                data: JSON.stringify({'senha':senha}),
                dataType: "json",
                success: function(data) {
                    if (data['status']) {
                        // fechar o modal
                        $("#confirmar_edicao_modal").modal('hide');
                        $("#btn_habilitar_edicao").remove();
                        $("#painel_Grade").append('<button id="btn_salvar" class="mt-3 btn btn-primary">Salvar</button>&nbsp;');
                        $("#painel_Grade").append('<button id="btn_limpar" class="mt-3 btn btn-secondary">Limpar Grade</button>&nbsp;');
                        $("#painel_Grade").append('<button id="btn_importar" class="mt-3 btn btn-success" data-bs-toggle="modal" data-bs-target="#importar_planilha_urania">Importar Planilha do Urânia</button>&nbsp;');
                        $("#painel_Grade").append('<button id="btn_importar_sed" class="mt-3 btn btn-warning">Importar da SED usando credenciais</button>');
                        $("#txt_num_classe").val($(".list-group-item.active").attr('data-id'));
                    } else {
                        $("#feedback").html('<div class="alert alert-danger alert-dismissible fade show" role="alert">Senha incorreta!<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
                    }
                },
            });
        });        

    </script>
</body>
</html>
