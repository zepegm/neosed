<!doctype html>
<html lang="pt-br">

    <head>
    
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Relatórios</title>
        <link href="{{ url_for('static', filename='bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">

        <!-- Custom styles for this template -->
        <link href="{{ url_for('static', filename='stylesheets/navbar-top-fixed.css') }}" rel="stylesheet">   
        <link href="{{ url_for('static', filename='font-awesome/css/fontawesome.min.css') }}" rel="stylesheet">
        <link href="{{ url_for('static', filename='font-awesome/css/brands.css') }}" rel="stylesheet">
        <link href="{{ url_for('static', filename='font-awesome/css/solid.css') }}" rel="stylesheet">
        <link href="{{ url_for('static', filename='datatable/datatables.min.css') }}" rel="stylesheet">
        <link rel="shortcut icon" type="image/png" href="{{ url_for('static', filename='images/icon_sed.png') }}">    
    

        <style>
            .titulo {
                margin-top: 3vh;
                color: gray;
            }

            .table {
                margin-bottom:5vh;
            }
        </style>
    </head>

    <body style="background-color: rgba(244, 244, 244);">
    
        {% block menu_superior %}
            {% include 'menu.jinja' %}
        {% endblock %}

        <main class="container-xxl">
        
            <form action="relatorios" method="POST">
                <div class="row">
                    <div class="col-sm-12">
                        <h1>Escolha o Relatório:</h1>               
                    </div>
                    <div class="col-sm-6">
                        <select class="form-select" id="cb_relatorio" name="cb_relatorio">
                            {% for item in combo_final %}
                            {{item}}
                            {% endfor %}
                        </select>                 
                    </div>
                    <div class="col-sm-6">
                        <input class="btn btn-primary" type="submit" value="Confirmar">
                    </div>
                </div>
            </form>

            {% if opcao == 0 or opcao == 1 or opcao == 2 %}

                {% for turma in turmas %}

                    {% if turma['alunos']|length > 0 %}
                    <hr>
                    <h3 class="text-danger">{{turma['nome_turma']}}</h3>
                        <ul>
                        {% for aluno in turma['alunos'] %}
                            
                        <li>{{aluno['nome']}} - <span class="text-primary">{{aluno['descricao']}}</span></li>

                        {% endfor %}
                        </ul>
                    {% endif %}

                {% endfor %}

                <hr>
                <p><b>Resultado: </b>Um total de <b>{{soma}}</b> alunos estão devendo {{text_final}}</p>

            {% elif opcao == 3 %}

                <button class="btn btn-danger mt-3" id="btn_exportar"><i class="fa-solid fa-file-pdf"></i>&nbsp;Exportar PDF</button>
            
                {% for item in titulos %}
                <h3 class="titulo">{{item}}</h3>

                <table class="table table-striped table-bordered">
                    <thead class="table-warning">
                        <tr>
                            <th>Nome</th>
                            <th>RG</th>
                            <th>CPF</th>
                            <th class="text-center">DI</th>
                            <th class="text-center">Nascimento</th>
                            <th class="text-center">Cat.</th>
                            <th class="text-center">Cargo</th>
                            <th class="text-center">RS/PV</th>
                            <th class="text-center">F/N</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in lista_final[loop.index - 1] %}
                        <tr>
                            <td>{{item['nome']}}</td>
                            <td>{{item['rg']}}</td>
                            <td>{{item['cpf']}}</td>
                            <td class="text-center">{{item['di']}}</td>
                            <td class="text-center">{{item['nascimento']}}</td>
                            <td class="text-center">{{item['categoria']}}</td>
                            <td class="text-center">{{item['abv']}}</td>
                            <td class="text-center">{{item['rs']}}/{{item['pv']}}</td>
                            <td class="text-center">{{item['FNREF']}}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% endfor %}

            {% endif %}

        </main>
        <script src="{{ url_for('static', filename='js/jquery-3.7.0.min.js') }}"></script> 
        <script>
            $("#btn_exportar").on('click', function() {
                $(this).attr('disabled');
                $(this).html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');

                info = {'destino':23}

                $.ajax({
                    type: "POST",
                    url: "gerar_pdf",
                    contentType: "application/json",
                    data: JSON.stringify(info),
                    dataType: "json",
                    success: function(data) {
                    window.open(data);
                    $("#btn_exportar").html('<i class="fa-solid fa-file-pdf"></i>&nbsp;Exportar PDF');
                    $("#btn_exportar").removeAttr('disabled');
                    },
                });
            });        
        </script>

    </body>

</html>