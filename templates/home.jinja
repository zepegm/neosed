                    </div>            
                    <div class="col-sm-6">
                        <label for="txtnometurma_if">Nome da turma:</label>
                        <input type="text" class="form-control" id="txtnometurma_if" name="txtnometurma_if" required>               
                    </div>

                    <div class="col-sm-6">
                        <label for="cbperiodo_if">Período:</label>
                        <select id="cbperiodo_if" name="cbperiodo_if" class="form-select" aria-label="Default select example">
                            {% for item in periodo %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>                   

                    <div class="col-sm-4">
                        <label for="cbduracao_if">Duração:</label>
                        <select id="cbduracao_if" name="cbduracao_if" class="form-select" aria-label="Default select example">
                            {% for item in duracao %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-12">
                        <label for="cbcategoria_if">Categoria:</label>
                        <select id="cbcategoria_if" name="cbcategoria_if" class="form-select" aria-label="Default select example">
                            {% for item in cat_itinerario %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-6">
                        <label for="cbtipoensino_if">Tipo de Ensino:</label>
                        <select id="cbtipoensino_if" name="cbtipoensino_if" class="form-select" aria-label="Default select example">
                            {% for item in tipo_ensino_itinerario %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>                  
                    
                </div>

                <div class="row">
                    <div class="col-sm-12">&nbsp;</div>
                    <div class="col-sm-12" id="alert_error_if"></div>
                    <div class="col-sm-6">
                        <div class="fw-bold">Ensino Médio Regular</div>
                        <div id="lista_geral" class="list-group">
                            {% for ensino in listaTurmas %}
                                {% if ensino['tipo_ensino']['id'] == 1 %}
                                    {% for turma in ensino['lista'] %}
                                        <li class="list-group-item"><label class="bold"><input class="form-check-input me-1" name="turmas_vinculo_if" type="checkbox" value='{{turma["num_classe"]}}'>{{turma['nome_turma']}}</label></li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                            
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="fw-bold">Ensino Médio EJA</div>
                       <div id="lista_geral" class="list-group">
                            {% for ensino in listaTurmas %}
                                {% if ensino['tipo_ensino']['id'] == 4 %}
                                    {% for turma in ensino['lista'] %}
                                        <li class="list-group-item"><label class="bold"><input class="form-check-input me-1" name="turmas_vinculo_if" type="checkbox" value='{{turma["num_classe"]}}'>{{turma['nome_turma']}}</label></li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                            
                        </div>                        
                    </div>                      
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <input type="submit" class="btn btn-success" value="Cadastrar Novo Itinerário Formativo" />
                <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
            </div>
            </form>
            </div>
        </div>
    </div>


