    <div class="modal fade" id="modal_lista_turma_if" tabindex="-1" aria-labelledby="modal_lista_turma_ifLabel" aria-hidden="true">
        <div class="modal-dialog" style="max-width: 90%;" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="modal_lista_turma_ifLabel">Lista dos Alunos</h1>
                    <span>&nbsp;</span>
                    <button id="btnExportarIf" class="btn btn-danger">Exportar PDF</button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-12">
                            <span class="fw-bold" id="desc_tipo_ensino_if"></span> - <span id="desc_tipo_ensino_nome_if"></span>
                        </div>                     
                        <div class="col-sm-12">
                            <span class="fw-bold">Turma: </span><span id="descTurma_if"></span>
                        </div>                       
                        <div class="col-sm-2">
                            <span class="fw-bold">Nº da Classe: </span><span id="numClasse_if"></span>
                        </div>  
                        <div class="col-sm-10">
                            <span class="fw-bold">Período: </span><span id="descPeriodo_if"></span>
                        </div>                          
                        <div class="col-sm-2">
                            <span class="fw-bold">Duração: </span><span id="descDuracao_if"></span>
                        </div>                        
                        <div class="col-sm-2">
                            <span class="fw-bold">Início da Turma: </span><span id="inicioTurma_if"></span>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-bold">Fim da Turma: </span><span id="fimTurma_if"></span>
                        </div>
                        <div class="col-sm-8">
                            <span class="fw-bold">Total: </span><span id="descTotal_if"></span>
                        </div>                                                                                                                
                        <div class="col-sm-12">&nbsp;</div>
                        <div id="tabelaAlunos_if" class="col-sm-12">
                            <table id="tabela_alunos_if" class="table table-hover"> 
                            <thead class="table-dark">
                                <tr>
                                    <th class="text-center">Nº</th>
                                    <th class="text-center">RM</th>
                                    <th>RA</th>
                                    <th>Nome</th>
                                    <th>Turma</th>
