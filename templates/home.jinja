    <main class="container">
        <div class="row">
            <div class="col-sm-12">
                <div class="icon"><img src="{{ url_for('static', filename='images/Logo Neo Sed.png') }}" class="d-inline-block align-top" alt=""></div>
            </div>
            <div class="col-sm-12">{{msg|safe}}</div>
            <div class="col-sm-10 align-self-end">
                <button id="btnNovaTurma" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#nova_turma_modal">Cadastrar Nova Turma</button>
                <button id="btnNovoItinerario" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#novo_itinerario_modal">Cadastrar Itinerário Formativo</button>
                <button id="btnUpdateAutomatico" class="btn btn-secondary">Atualizar Listas Automaticamente</button>
                <span id="status_auto_update"></span>
            </div>
            <div class="col-sm-1 align-self-center" style="text-align:right;">
                <label for="cbAno">Ano:</label>
            </div>
            <div class="col-sm-1" style="text-align:right;">
                <form id="mudarAno" method="post" action="{{ url_for('index') }}">
                <select id="cbAno" name="cbAno" class="form-select" aria-label="Default select example">
                    {% for ano in anos %}
                        <option value="{{ano['ano']}}" {{ano['selected']}}>{{ano['ano']}}</option>
                    {% endfor %}
                </select>                 
                </form>
            </div>
        </div>
        <div class="row">&nbsp;</div>
        <div class="row">
            <div class="col-sm-12">
                   
                {% for item in listaTurmas %}                                     
                <table class="table table-hover table-striped">   
                    <thead class="{{item['color']}}">
                    <!-- <thead class="table-dark"> -->
                        <tr>
                            <th colspan="5">{{item['tipo_ensino']['tipo_ensino']}}</th>
                            <th colspan="2">Total de turmas: {{item['tipo_ensino']['total']}}</th>
                        </tr>
                    </thead>
                    <thead class="table-warning">
                        <tr>
                            <th>Nome da Turma</th>
                            <th class="text-center">Número da Classe</th>
                            <th class="text-center">Período</th>
                            <th class="text-center">Duração</th>
                            <th class="text-center">Matriz Curricular</th>
                            <th class="text-center">Visualizar</th>
                            <th class="text-center">Editar</th>
                        </tr>
                    </thead>                     
                    <tbody class="table-light">
                        {% for turma in item['lista'] %}
                            <tr>
                                <td>{{turma['nome_turma']}}</td>
                                <td class="text-center">{{turma['num_classe']}}</td>
                                <td class="text-center">{{turma['periodo']}}</td>
                                <td class="text-center">{{turma['duracao']}}</td>
                                <td class="text-center"><a href="javascript:abrirMatriz({{turma['num_classe']}}, '{{turma['duracao']}}')"><i class="fa-solid fa-table-list"></i></a></td>
                                {% if item['tipo_ensino']['id'] != 2 and item['tipo_ensino']['id'] != 5 %}
                                <td class="text-center"><a href="javascript:consultar({{turma['num_classe']}}, '{{turma['nome_turma']}}', '{{turma['duracao']}}', '{{turma['periodo']}}', '{{item['tipo_ensino']['tipo_ensino']}}')"><i class="fa-solid fa-search"></i></a></td>
                                <td class="text-center"><a href="javascript:editar({{turma['num_classe']}}, '{{turma['nome_turma']}}', {{turma['id_ensino']}}, {{turma['id_periodo']}}, {{turma['id_duracao']}})"><i class="fa-solid fa-edit"></i></a></td>
                                {% else %}
                                <td class="text-center"><a href="javascript:consultarIf({{turma['num_classe']}}, '{{turma['nome_turma']}}', '{{turma['duracao']}}', '{{turma['periodo']}}', '{{item['tipo_ensino']['tipo_ensino']}}')"><i class="fa-solid fa-search"></i></a></td>
                                <td class="text-center"><a href="javascript:editarIf({{turma['num_classe']}}, '{{turma['nome_turma']}}', {{turma['id_ensino']}}, {{turma['id_periodo']}}, {{turma['id_duracao']}}, {{turma['categoria']}})"><i class="fa-solid fa-edit"></i></a></td>                            
                                
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody></table>
                {% endfor %}
            </div>
        </div>
    </main>
    <script src="{{ url_for('static', filename='js/jquery-3.7.0.min.js') }}"></script> 
    <script src="{{ url_for('static', filename='js/jquery.mask.min.js') }}"></script> 
    <script src="{{ url_for('static', filename='bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ url_for('static', filename='datatable/datatables.min.js') }}"></script>
    <script src="{{ url_for('static', filename='js/diacritics-sort.js') }}"></script>
    <script src="{{ url_for('static', filename='jspdf/jspdf.umd.min.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/BebasKai-normal.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/GreatVibes-Regular-normal.js') }}"></script>  
    <script src="{{ url_for('static', filename='js/gerador-pdf.js') }}"></script>
    <script src="{{ url_for('static', filename='js/socket.io.min.js') }}"></script>
    <script>

        var matriz_dias_anual = 0;
        var num_classe_matriz = 0;
        var professores = {{professores}};

        var socket = io();
        socket.on('update_info', function(html) {
            $("#status_auto_update").html(html)
        }); 

        $("#btn_puxar_matriz").on('click', function() {
            $(this).html('<div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>');
            $(this).attr('disabled');
            $("#status_auto_update").html('<b>Aguarde...</b>')

            $.ajax({
                type: "POST",
                url: "atualizar_matriz_auto",
                contentType: "application/json",
                data: JSON.stringify({'num_classe':num_classe_matriz, 'minutos':$("#txt_min").val()}),
                dataType: "json",
                success: function(data) {
                    if (data.length > 0) {
                        $("#hidden_matriz").val(JSON.stringify(data));
                        $("#form-enviar-matriz").submit();
                    } else {
                        $("#btn_puxar_matriz").html('Erro na SED! Tente novamente!');
                        $("#btn_puxar_matriz").removeAttr('disabled');
                    }
                    
                },
            });                 
        });

        $("#btn_salvar_matriz").on('click', function() {
            var matriz = [];
            $("#tabela_matriz tr").each(function() {
                let tipo = $(this).find('td:eq(0)').attr('data-id');
                let area = $(this).find('td:eq(1)').attr('data-id');
                let disc = $(this).find('td:eq(2)').attr('data-id');
                let qtd = $(this).find('td:eq(3)').text();
                let minutos = $(this).find('td:eq(4)').text();
                matriz.push({num_classe:num_classe_matriz, tipo: tipo, area: area, disc: disc, qtd: qtd, minutos: minutos});
            });

            $("#hidden_matriz").val(JSON.stringify(matriz));
            $("#form-enviar-matriz").submit();
        })

        $("#btn_add_disc").on('click', function() {

            var id_tipo = $("#cb_tipo_matriz").val();
            let tipo = $("#cb_tipo_matriz option:selected").text();
            var id_area = '0';
            var area = $("#cb_area_matriz option:selected").text();
            let disc = $(".item-disc.active").attr('data-id');
            let disc_nome = $(".item-disc.active").text();
            let qtd = $("#txt_qtd").val();
            let minutos = $("#txt_min").val();

            if (id_tipo == '1' || id_tipo == '3') {
                id_area = $("#cb_area_matriz").val();
            } else {
                area  = '-';
            }

            let row = `<tr>`;
            row += `<td data-id="${id_tipo}">${tipo}</td>`;
            row += `<td data-id="${id_area}">${area}</td>`;
            row += `<td data-id="${disc}">${disc_nome}</td>`;
            row += `<td class="text-center">${qtd}</td>`;
            row += `<td class="text-center">${minutos}</td>`;

            row += `<td class="text-center">-</td><td class="text-center">-</td>`;

            row += '<td class="text-center"><a href="#" class="remover-disciplina"><i class="fa-solid fa-trash"></i></a></td>';
            row += '</tr>';

            $("#tabela_matriz").append(row);
            calcularMatriz();
        });

        $("#cb_tipo_matriz").on('change', function() {

            if ([1, 3].includes(parseInt($(this).val()))) {
                $("#cb_area_matriz").removeAttr('disabled');
            } else {
                $("#cb_area_matriz").attr('disabled', '');              
            }
        });

        function calcularMatriz() {
            
            var total_aulas_fgb = 0;
            var total_aulas_if = 0;

            var total_horas_fgb = 0;
            var total_horas_if = 0;

            $("#tabela_matriz tr").each(function() {

                if ($(this).find('td:eq(0)').text() == 'FGB' || $(this).find('td:eq(0)').text() == 'BNC') {
                    total_aulas_fgb += parseInt($(this).find('td:eq(3)').text());
                    total_horas_fgb += parseInt($(this).find('td:eq(3)').text()) * parseInt($(this).find('td:eq(4)').text()) / 60;
                    console.log(total_horas_fgb);
                } else {
                    total_aulas_if += parseInt($(this).find('td:eq(3)').text());
                    total_horas_if += parseInt($(this).find('td:eq(3)').text()) * parseInt($(this).find('td:eq(4)').text()) / 60;
                }

            });

            // calcular o valor anual
            total_aulas_fgb = total_aulas_fgb * matriz_dias_anual;
            total_horas_fgb = total_horas_fgb * matriz_dias_anual;

            total_aulas_if = total_aulas_if * matriz_dias_anual;
            total_horas_if = total_horas_if * matriz_dias_anual;
            
            $("#lb_aulas_fgb").text(total_aulas_fgb);
            $("#lb_horas_fgb").text(Math.round(total_horas_fgb));

            $("#lb_aulas_if").text(total_aulas_if);
            $("#lb_horas_if").text(Math.round(total_horas_if));
            
            $("#lb_total_aulas").text(total_aulas_fgb + total_aulas_if);
            $("#lb_total_horas").text(Math.round(total_horas_fgb + total_horas_if));
        }

        $(document).on('dblclick', '.cb-professor-matriz', function() {
            $(this).removeAttr('disabled');
            console.log('teste');
        });

        $(document).on('click', '.remover-disciplina', function() {
            $(this).closest('tr').remove();
            calcularMatriz();
        });

        $(document).on('click', '.item-disc', function() {
            $(".item-disc").removeClass('active');
            $(this).addClass('active');
            $("#selecionarDisc").text($(this).text());
        });

        $(document).on('keyup', '#txt_filtro', function() {
            val = $(this).val().normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();

            $(".dropdown-item").each(function(index) {
            //console.log($(this).text().toLowerCase().normalize("NFD") + " - " + val);
            if ($(this).text().normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().indexOf(val) !== - 1) {
                $(this).removeClass('toggled');
            } else {
                $(this).addClass('toggled');
            }
            });


            // verificar estado das listas
            let totalA = $(".dropdown-item").not('.toggled').length

            if (totalA < 1) {
                $(".noResult").removeClass('toggled');
            } else {
                $(".noResult").addClass('toggled');
            }

        });        

        function abrirMatriz(num_classe, duracao) {

            num_classe_matriz = num_classe;

            if (duracao == 'Anual') {
                matriz_dias_anual = 40;
            } else {
                matriz_dias_anual = 20;                
            }

            $.ajax({
                type: "POST",
                url: "{{ url_for('index') }}",
                contentType: "application/json",
                data: JSON.stringify(num_classe),
                dataType: "json",
                success: function(data) {
                    $("#tabela_matriz").empty();

                    for (let i = 0; i < data.length; i++) {
                        let row = `<tr>`;
                        row += `<td data-id="${data[i].tipo}">${data[i].desc_tipo}</td>`;
                        row += `<td data-id="${data[i].area}">${data[i].desc_area}</td>`;
                        row += `<td data-id="${data[i].disc}">${data[i].disc} - ${data[i].desc_disc}</td>`;
                        row += `<td class="text-center">${data[i].qtd_aulas}</td>`;
                        row += `<td class="text-center">${data[i].minutos}</td>`;
                        
                        row += `<td><select class="form-select cb-professor-matriz" disabled>`;
                        row += '<option value="0">Selecione o professor</option>';
                        for (let j = 0; j < professores.length; j++) {
                            row += `<option value="${professores[j].id}">${professores[j].nome}</option>`;
                        }
                        row += '</select></td>'
                        row += '<td class="apelido-edit"></td>'

                        row += '<td class="text-center"><a href="#" class="remover-disciplina"><i class="fa-solid fa-trash"></i></a></td>';
                        row += '</tr>';
                        $("#tabela_matriz").append(row);
                    }

                    calcularMatriz();
                },
            });              

            $("#matriz_modal").modal('show');
        }

        $("#form-add-turma").on('submit', function() {
            $("#hidden_year").val($("#cbAno").val());
        });


        $("#btnUpdateAutomatico").on('click', function() {
            $(this).html('<div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div>');
            $("#status_auto_update").html('<b>Aguarde...</b>')

            $.ajax({
                type: "POST",
                url: "atualizar_lista_auto",
                contentType: "application/json",
                data: JSON.stringify($("#cbAno").val()),
                dataType: "json",
                success: function(data) {
                    $("#status_auto_update").html('<b>Processo concluído...</b>')
                    $("#btnUpdateAutomatico").html('Atualizar Listas Automaticamente');
                },
            });            
        });


        $("#cbAno").on('change', function() {
            $("#mudarAno").submit();
        });

        $("#form_cadastrar_itinerario").on('submit', function(e) {
            if ($("[name='turmas_vinculo_if']:checked").length < 1) {
                e.preventDefault();
                $("#alert_error_if").append('<div class="alert alert-warning alert-dismissible fade show" role="alert"><strong>Atenção!</strong> Favor selecionar as turmas que terão vínculo com a classe do Itinerário.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            }
        });

        $("#form_editar_itinerario").on('submit', function(e) {
            if ($("[name='turmas_vinculo_if_edit']:checked").length < 1) {
                e.preventDefault();
                $("#alert_error_if_edit").append('<div class="alert alert-warning alert-dismissible fade show" role="alert"><strong>Atenção!</strong> Favor selecionar as turmas que terão vínculo com a classe do Itinerário.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            }
        });        

        $("#btnExportarTurma").on('click', function(e) {

            $("#btnExportarTurma").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btnExportarTurma").attr('disabled', '');

            info = {'destino':1, 'turma':$("#numClasse").text(), 'tipo':'turma', 'order':$("#cb_pdf_order").val()}

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btnExportarTurma").html('Exportar PDF');
                $("#btnExportarTurma").removeAttr('disabled');
                },
            });

            
        });

        $("#btnGerarCertificado").on('click', function() {
            $("#btnGerarCertificado").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btnGerarCertificado").attr('disabled', '');

            info = {'destino':8, 'classe':$("#numClasse").text()}

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btnGerarCertificado").html('Gerar Certificados');
                $("#btnGerarCertificado").removeAttr('disabled');
                },
            });            
        });

        $("#btnExportarIf").on('click', function(e) {

            $("#btnExportarIf").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btnExportarIf").attr('disabled', '');

            info = {'destino':2, 'turma':$("#numClasse_if").text(), 'tipo':'turma_if'}

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btnExportarIf").html('Exportar PDF');
                $("#btnExportarIf").removeAttr('disabled');
                },
            });
           
            
        });        

        function consultarIf(id, nome, duracao, periodo, tipo_ensino) {

            $("#descTurma_if").text(nome);
            $("#numClasse_if").text(id);
            $("#descDuracao_if").text(duracao);
            $("#descPeriodo_if").text(periodo);
            $("#desc_tipo_ensino_if").text(tipo_ensino);

            $.ajax({
                type: "POST",
                url: "{{ url_for('getAlunosTurmaIF') }}",
                contentType: "application/json",
                data: JSON.stringify(id),
                dataType: "json",
                success: function(response) {
                    //console.log(response);
                    $("#desc_tipo_ensino_nome_if").text(response['info']['categoria']);
                    $("#inicioTurma_if").text(response['info']['inicio']);
                    $("#fimTurma_if").text(response['info']['fim']);
                    $("#descTotal_if").html('<span class="fw-bold text-secondary">' + response['total']['ativos'] + '</span> ativos (<span class="fw-bold text-secondary">' + response['total']['total'] + ' </span>no total).');

                    $("#tabelaAlunos_if").empty();
                    $("#tabelaAlunos_if").append('<table id="tabela_alunos_if" class="table table-hover"><thead class="table-dark"><tr><th class="text-center">Nº</th><th class="text-center">RM</th><th>RA</th><th>Nome</th><th>Turma</th><th class="text-center">Matrícula</th><th class="text-center">Fim Matr.</th><th class="text-center">Situação</th></tr></thead><tbody id="listaAlunos_if"></tbody></table>');

                    $("#listaAlunos_if").empty();
                    for (var item in response['turma']) {

                        var linha = "";

                        console.log(response['turma'][item]['sit']);

                        if (response['turma'][item]['sit'] != "ATIVO" && response['turma'][item]['sit'] != "APROV") {
                            linha += '<tr class="red">'
                        } else {
                            linha += "<tr>"
                        }

                        linha += '<td class="text-center">' + response['turma'][item]['num_chamada'] + '</td><td class="text-center">' + response['turma'][item]['rm'] + "</td><td>" + response['turma'][item]['ra'] + "</td><td>" + response['turma'][item]['nome'] + "</td>" + "<td>" + response['turma'][item]['turma'] + "</td>";
                        

                        linha += '<td class="text-center" data-order="' + response['turma'][item]['matricula_original'] + '">' + response['turma'][item]['matricula'] + "</td>";
