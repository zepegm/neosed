    <!-- Modal -->
    <div class="modal fade" id="nova_turma_modal" tabindex="-1" aria-labelledby="nova_turma_modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="nova_turma_modalLabel">Nova Turma</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="{{ url_for('index') }}" method="post">
            <div class="modal-body">
                <div class="row">
                    <div class="col-sm-6">
                        <label for="txtnumeroclasse">Número da Classe:</label>
                        <input type="number" class="form-control" id="txtnumeroclasse" name="txtnumeroclasse" required>               
                    </div>            
                    <div class="col-sm-6">
                        <label for="txtnometurma">Nome da turma:</label>
                        <input type="text" class="form-control" id="txtnometurma" name="txtnometurma" required>               
                    </div>

                    <div class="col-sm-6">
                        <label for="cbtipoensino">Tipo de Ensino:</label>
                        <select id="cbtipoensino" name="cbtipoensino" class="form-select" aria-label="Default select example">
                            {% for item in tipo_ensino %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-6">
                        <label for="cbperiodo">Período:</label>
                        <select id="cbperiodo" name="cbperiodo" class="form-select" aria-label="Default select example">
                            {% for item in periodo %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div> 

                    <div class="col-sm-4">
                        <label for="cbduracao">Duração:</label>
                        <select id="cbduracao" name="cbduracao" class="form-select" aria-label="Default select example">
                            {% for item in duracao %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-4 align-self-end">
                        <div><span class="fw-bold">Início: </span><span id="infoinicio">{{calendario['1sem_inicio']}}</span></div>
                        <div><span class="fw-bold">Fim: </span><span id="infofim">{{calendario['2sem_fim']}}</span></div>
                    </div>

                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <input type="submit" class="btn btn-primary" value="Cadastrar Nova Turma" />
                <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
            </div>
            </form>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="novo_itinerario_modal" tabindex="-1" aria-labelledby="novo_itinerario_modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="novo_itinerario_modalLabel">Nova Turma de Itinerário Formativo</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="{{ url_for('index') }}" method="post" id="form_cadastrar_itinerario">
            <div class="modal-body">
                <div class="row">
                    <div class="col-sm-6">
                        <label for="txtnumeroclasse_if">Número da Classe:</label>
                        <input type="number" class="form-control" id="txtnumeroclasse_if" name="txtnumeroclasse_if" required>               
                    </div>            
                    <div class="col-sm-6">
                        <label for="txtnometurma_if">Nome da turma:</label>
                        <input type="text" class="form-control" id="txtnometurma_if" name="txtnometurma_if" required>               
                    </div>

                    <div class="col-sm-6">
                        <label for="cbperiodo_if">Período:</label>
                        <select id="cbperiodo_if" name="cbperiodo_if" class="form-select" aria-label="Default select example">
                            {% for item in periodo %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>                   

                    <div class="col-sm-4">
                        <label for="cbduracao_if">Duração:</label>
                        <select id="cbduracao_if" name="cbduracao_if" class="form-select" aria-label="Default select example">
                            {% for item in duracao %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-12">
                        <label for="cbcategoria_if">Categoria:</label>
                        <select id="cbcategoria_if" name="cbcategoria_if" class="form-select" aria-label="Default select example">
                            {% for item in cat_itinerario %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>

                    <div class="col-sm-6">
                        <label for="cbtipoensino_if">Tipo de Ensino:</label>
                        <select id="cbtipoensino_if" name="cbtipoensino_if" class="form-select" aria-label="Default select example">
                            {% for item in tipo_ensino_itinerario %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                            {% endfor %}
                        </select>                    
                    </div>                  
                    
                </div>

                <div class="row">
                    <div class="col-sm-12">&nbsp;</div>
                    <div class="col-sm-12" id="alert_error_if"></div>
                    <div class="col-sm-6">
                        <div class="fw-bold">Ensino Médio Regular</div>
                        <div id="lista_geral" class="list-group">
                            {% for ensino in listaTurmas %}
                                {% if ensino['tipo_ensino']['id'] == 1 %}
                                    {% for turma in ensino['lista'] %}
                                        <li class="list-group-item"><label class="bold"><input class="form-check-input me-1" name="turmas_vinculo_if" type="checkbox" value='{{turma["num_classe"]}}'>{{turma['nome_turma']}}</label></li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                            
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="fw-bold">Ensino Médio EJA</div>
                       <div id="lista_geral" class="list-group">
                            {% for ensino in listaTurmas %}
                                {% if ensino['tipo_ensino']['id'] == 4 %}
                                    {% for turma in ensino['lista'] %}
                                        <li class="list-group-item"><label class="bold"><input class="form-check-input me-1" name="turmas_vinculo_if" type="checkbox" value='{{turma["num_classe"]}}'>{{turma['nome_turma']}}</label></li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                            
                        </div>                        
                    </div>                      
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <input type="submit" class="btn btn-success" value="Cadastrar Novo Itinerário Formativo" />
                <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
            </div>
            </form>
            </div>
        </div>
    </div>


    <!-- Modal -->
