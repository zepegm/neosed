<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AVG - NeoSED</title>
    <link href="{{ url_for('static', filename='bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">

    <!-- Custom styles for this template -->
    <link href="{{ url_for('static', filename='stylesheets/navbar-top-fixed.css') }}" rel="stylesheet">   
    <link href="{{ url_for('static', filename='font-awesome/css/fontawesome.min.css') }}" rel="stylesheet">
    <link href="{{ url_for('static', filename='font-awesome/css/brands.css') }}" rel="stylesheet">
    <link href="{{ url_for('static', filename='font-awesome/css/solid.css') }}" rel="stylesheet">    
    <link href="{{ url_for('static', filename='datatable/datatables.min.css') }}" rel="stylesheet">    
    <link rel="shortcut icon" type="image/png" href="{{ url_for('static', filename='images/icon_sed.png') }}">

    <style>
        .icon {
            text-align: center;
            margin-top: -90px;
            margin-bottom: -100px;
        }

        img {
            pointer-events: none;
        }   

        .red {
            color:red;
        }   

        #txt_filtro {
            width: 90%;
            position: relative;
            left: 5%;
            border: solid black 1px;
        }

        .dropdown-item-text {
            font-weight: bold;
            font-size:large;
        }        

        .toggled { display: none; }

        #selecionarDisc {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    </style>

  </head>
  <body style="background-color: rgba(244, 244, 244);">

    {% block menu_superior %}
      {% include 'menu.jinja' %}
    {% endblock %}

    <!-- Modal -->
    <div class="modal fade" id="matriz_modal" tabindex="-1" aria-labelledby="matriz_modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="matriz_modalLabel">Matriz Curricular</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-sm-2">
                            <label class="form-label" for="cb_tipo_matriz">Tipo:</label>
                            <select id="cb_tipo_matriz" class="form-select" aria-label="Default select example">
                                {% for item in tipo_disc %}
                                <option value="{{item['id']}}">{{item['descricao']}}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-sm-2">
                            <label class="form-label" for="cb_area_matriz">Área:</label>
                            <select id="cb_area_matriz" class="form-select" aria-label="Default select example">
                                {% for item in area_conhecimento %}
                                <option value="{{item['id']}}">{{item['desc_curta']}}</option>
                                {% endfor %}
                            </select>                        
                        </div>

                        <div class="col-sm-3 d-flex align-items-end dropdown">
                            <button class="btn btn-secondary dropdown-toggle w-100 d-block text-truncate" type="button" id="selecionarDisc" data-bs-toggle="dropdown" aria-expanded="false">
                            Selecione a Disciplina
                            </button>
                            <ul id="ul_disc" class="dropdown-menu" aria-labelledby="selecionarDisc">
                            <input type="text" id="txt_filtro">
                            {% for item in disc %}              
                            <li><a class="dropdown-item item-disc" href="#" data-id="{{item['codigo_disciplina']}}">{{item['codigo_disciplina']}} - {{item['descricao']}}</a></li>
                            {% endfor %}
                            <div class="dropdown-divider noResult toggled"></div>
                            <span class="dropdown-item-text toggled noResult">Nenhum resultado</span>
                            </ul>                                                             
                        </div>

                        <div class="col-sm-2">
                            <label class="form-label" for="txt_qtd">Qtd. Aulas</label>
                            <input type="number" class="form-control" id="txt_qtd" name="txt_qtd" value="0">
                        </div>

                        <div class="col-sm-2">
                            <label class="form-label" for="txt_min">Minutos</label>
                            <input type="number" class="form-control" id="txt_min" name="txt_min" value="45">
                        </div>

                        <div class="col-sm-1 d-flex align-items-end">
                            <button id="btn_add_disc" class="btn btn-success"><i class="fa-solid fa-plus"></i></button>
                        </div>

                    </div>

                    <div class="row">
                        <div class="col-sm-12">
                            <table class="table table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Área</th>
                                        <th>Disciplina</th>
                                        <th>Qtd. Aulas</th>
                                        <th>Minutos</th>
                                        <th>Professor</th>
                                        <th>Apelido</th>
                                        <th class="text-center">Excluir</th>
                                    </tr>
                                </thead>
                                <tbody id="tabela_matriz"></tbody>
                            </table>
                        </div>
                        <div class="col-sm-6">
                            <table class="table">
                                <thead class="table-warning">
                                    <tr>
                                        <th>Total Anual</th>
                                        <th>Aulas</th>
                                        <th>Horas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>FGB/BNC</td>
                                        <td id="lb_aulas_fgb">0</td>
                                        <td id="lb_horas_fgb">0</td>
                                    </tr>
                                    <tr>
                                        <td>IF/DIV</td>
                                        <td id="lb_aulas_if">0</td>
                                        <td id="lb_horas_if">0</td>
                                    </tr>
                                    <tr>
                                        <th>Total</th>
                                        <td id="lb_total_aulas">0</td>
                                        <td id="lb_total_horas">0</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-success" id="btn_puxar_matriz">Puxar Matriz da SED</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btn_salvar_matriz">Salvar Matriz</button>
                </div>
                
            </div>
        </div>
    </div>

    <form id="form-enviar-matriz" method="post" action="/">
        <input type="hidden" name="matriz" id="hidden_matriz" value="">
    </form>

    <!-- Modal -->
    <div class="modal fade" id="nova_turma_modal" tabindex="-1" aria-labelledby="nova_turma_modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="nova_turma_modalLabel">Nova Turma</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="form-add-turma" action="{{ url_for('index') }}" method="post">
                <input type="hidden" name="ano" id="hidden_year" value="">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <label for="txtnumeroclasse">Número da Classe:</label>
                            <input type="number" class="form-control" id="txtnumeroclasse" name="txtnumeroclasse" required>               
                        </div>            
                        <div class="col-sm-6">
                            <label for="txtnometurma">Nome da turma:</label>
                            <input type="text" class="form-control" id="txtnometurma" name="txtnometurma" required>               
                        </div>

                        <div class="col-sm-6">
                            <label for="cbtipoensino">Tipo de Ensino:</label>
                            <select id="cbtipoensino" name="cbtipoensino" class="form-select" aria-label="Default select example">
                                {% for item in tipo_ensino %}
                                    <option value="{{item['id']}}">{{item['descricao']}}</option>
                                {% endfor %}
                            </select>                    
                        </div>

                        <div class="col-sm-6">
                            <label for="cbperiodo">Período:</label>
                            <select id="cbperiodo" name="cbperiodo" class="form-select" aria-label="Default select example">
                                {% for item in periodo %}
                                    <option value="{{item['id']}}">{{item['descricao']}}</option>
                                {% endfor %}
                            </select>                    
                        </div> 

                        <div class="col-sm-4">
                            <label for="cbduracao">Duração:</label>
                            <select id="cbduracao" name="cbduracao" class="form-select" aria-label="Default select example">
                                {% for item in duracao %}
                                    <option value="{{item['id']}}">{{item['descricao']}}</option>
                                {% endfor %}
                            </select>                    
                        </div>

                        <div class="col-sm-4 align-self-end">
                            <div><span class="fw-bold">Início: </span><span id="infoinicio">{{calendario['1sem_inicio']}}</span></div>
                            <div><span class="fw-bold">Fim: </span><span id="infofim">{{calendario['2sem_fim']}}</span></div>
                        </div>

                    </div>
                </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <input type="submit" class="btn btn-primary" value="Cadastrar Nova Turma" />
                        <!-- <button type="button" class="btn btn-primary">Cadastrar Nova Turma</button> -->
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="novo_itinerario_modal" tabindex="-1" aria-labelledby="novo_itinerario_modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
