    <div class="modal fade" id="modal_lista_turmas" tabindex="-1" aria-labelledby="modal_lista_turmasLabel" aria-hidden="true">
        <div class="modal-dialog" style="max-width: 90%;" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="modal_lista_turmasLabel">Lista dos Alunos</h1><span>&nbsp;</span><button id="btnExportarTurma" class="btn btn-danger">Exportar PDF</button> 
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>                  
                </div>
                <div class="modal-body">
