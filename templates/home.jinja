    <main class="container">
        <div class="row">
            <div class="col-sm-12">
                <div class="icon"><img src="{{ url_for('static', filename='images/Logo Neo Sed.png') }}" class="d-inline-block align-top" alt=""></div>
            </div>
            <div class="col-sm-12">{{msg|safe}}</div>
            <div class="col-sm-10 align-self-end">
                <button id="btnNovaTurma" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#nova_turma_modal">Cadastrar Nova Turma</button>
                <button id="btnNovoItinerario" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#novo_itinerario_modal">Cadastrar Itinerário Formativo</button>
            </div>
            <div class="col-sm-1 align-self-center" style="text-align:right;">
                <label for="cbAno">Ano:</label>
            </div>
            <div class="col-sm-1" style="text-align:right;">
                <form id="mudarAno" method="post" action="{{ url_for('index') }}">
                <select id="cbAno" name="cbAno" class="form-select" aria-label="Default select example">
                    {% for ano in anos %}
                        <option value="{{ano['ano']}}" {{ano['selected']}}>{{ano['ano']}}</option>
                    {% endfor %}
                </select>                 
                </form>
            </div>
        </div>
        <div class="row">&nbsp;</div>
        <div class="row">
            <div class="col-sm-12">
                   
                {% for item in listaTurmas %}                                     
                <table class="table table-hover table-striped">   
                    <thead class="{{item['color']}}">
                    <!-- <thead class="table-dark"> -->
                        <tr>
                            <th colspan="4">{{item['tipo_ensino']['tipo_ensino']}}</th>
                            <th colspan="2">Total de turmas: {{item['tipo_ensino']['total']}}</th>
                        </tr>
                    </thead>
                    <thead class="table-warning">
                        <tr>
                            <th>Nome da Turma</th>
                            <th class="text-center">Número da Classe</th>
                            <th class="text-center">Período</th>
                            <th class="text-center">Duração</th>
                            <th class="text-center">Visualizar</th>
                            <th class="text-center">Editar</th>
                        </tr>
                    </thead>                     
                    <tbody class="table-light">
                        {% for turma in item['lista'] %}
                            <tr>
                                <td>{{turma['nome_turma']}}</td>
                                <td class="text-center">{{turma['num_classe']}}</td>
                                <td class="text-center">{{turma['periodo']}}</td>
                                <td class="text-center">{{turma['duracao']}}</td>
                                {% if item['tipo_ensino']['id'] != 2 and item['tipo_ensino']['id'] != 5 %}
                                <td class="text-center"><a href="javascript:consultar({{turma['num_classe']}}, '{{turma['nome_turma']}}', '{{turma['duracao']}}', '{{turma['periodo']}}', '{{item['tipo_ensino']['tipo_ensino']}}')"><i class="fa-solid fa-search"></i></a></td>
                                <td class="text-center"><a href="javascript:editar({{turma['num_classe']}}, '{{turma['nome_turma']}}', {{turma['id_ensino']}}, {{turma['id_periodo']}}, {{turma['id_duracao']}})"><i class="fa-solid fa-edit"></i></a></td>
                                {% else %}
                                <td class="text-center"><a href="javascript:consultarIf({{turma['num_classe']}}, '{{turma['nome_turma']}}', '{{turma['duracao']}}', '{{turma['periodo']}}', '{{item['tipo_ensino']['tipo_ensino']}}')"><i class="fa-solid fa-search"></i></a></td>
                                <td class="text-center"><a href="javascript:editarIf({{turma['num_classe']}}, '{{turma['nome_turma']}}', {{turma['id_ensino']}}, {{turma['id_periodo']}}, {{turma['id_duracao']}}, {{turma['categoria']}})"><i class="fa-solid fa-edit"></i></a></td>                            
                                
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody></table>
                {% endfor %}
            </div>
        </div>
    </main>
    <script src="{{ url_for('static', filename='js/jquery-3.7.0.min.js') }}"></script> 
    <script src="{{ url_for('static', filename='js/jquery.mask.min.js') }}"></script> 
    <script src="{{ url_for('static', filename='bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ url_for('static', filename='datatable/datatables.min.js') }}"></script>
    <script src="{{ url_for('static', filename='jspdf/jspdf.umd.min.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/BebasKai-normal.js') }}"></script>
    <script src="{{ url_for('static', filename='font-custom/GreatVibes-Regular-normal.js') }}"></script>  
    <script src="{{ url_for('static', filename='js/gerador-pdf.js') }}"></script>  
    <script>


        $("#cbAno").on('change', function() {
            $("#mudarAno").submit();
        });

        $("#form_cadastrar_itinerario").on('submit', function(e) {
            if ($("[name='turmas_vinculo_if']:checked").length < 1) {
                e.preventDefault();
                $("#alert_error_if").append('<div class="alert alert-warning alert-dismissible fade show" role="alert"><strong>Atenção!</strong> Favor selecionar as turmas que terão vínculo com a classe do Itinerário.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            }
        });

        $("#form_editar_itinerario").on('submit', function(e) {
            if ($("[name='turmas_vinculo_if_edit']:checked").length < 1) {
                e.preventDefault();
                $("#alert_error_if_edit").append('<div class="alert alert-warning alert-dismissible fade show" role="alert"><strong>Atenção!</strong> Favor selecionar as turmas que terão vínculo com a classe do Itinerário.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
            }
        });        

        $("#btnExportarTurma").on('click', function(e) {

            $("#btnExportarTurma").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btnExportarTurma").attr('disabled', '');

            info = {'destino':1, 'turma':$("#numClasse").text(), 'tipo':'turma'}

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btnExportarTurma").html('Exportar PDF');
                $("#btnExportarTurma").removeAttr('disabled');
                },
            });

            
        });

        $("#btnExportarIf").on('click', function(e) {

            $("#btnExportarIf").html('<div class="spinner-border text-ligth" role="status"><span class="sr-only">Carregando...</span></div>');
            $("#btnExportarIf").attr('disabled', '');

            info = {'destino':2, 'turma':$("#numClasse_if").text(), 'tipo':'turma_if'}

            $.ajax({
                type: "POST",
                url: "gerar_pdf",
                contentType: "application/json",
                data: JSON.stringify(info),
                dataType: "json",
                success: function(data) {
                window.open(data);
                $("#btnExportarIf").html('Exportar PDF');
                $("#btnExportarIf").removeAttr('disabled');
                },
            });
           
            
        });        

        function consultarIf(id, nome, duracao, periodo, tipo_ensino) {

            $("#descTurma_if").text(nome);
            $("#numClasse_if").text(id);
            $("#descDuracao_if").text(duracao);
            $("#descPeriodo_if").text(periodo);
            $("#desc_tipo_ensino_if").text(tipo_ensino);

            $.ajax({
                type: "POST",
                url: "{{ url_for('getAlunosTurmaIF') }}",
                contentType: "application/json",
                data: JSON.stringify(id),
                dataType: "json",
                success: function(response) {
                    //console.log(response);
                    $("#desc_tipo_ensino_nome_if").text(response['info']['categoria']);
                    $("#inicioTurma_if").text(response['info']['inicio']);
                    $("#fimTurma_if").text(response['info']['fim']);
                    $("#descTotal_if").html('<span class="fw-bold text-secondary">' + response['total']['ativos'] + '</span> ativos (<span class="fw-bold text-secondary">' + response['total']['total'] + ' </span>no total).');

                    $("#tabelaAlunos_if").empty();
                    $("#tabelaAlunos_if").append('<table id="tabela_alunos_if" class="table table-hover"><thead class="table-dark"><tr><th class="text-center">Nº</th><th class="text-center">RM</th><th>RA</th><th>Nome</th><th>Turma</th><th class="text-center">Matrícula</th><th class="text-center">Fim Matr.</th><th class="text-center">Situação</th></tr></thead><tbody id="listaAlunos_if"></tbody></table>');

                    $("#listaAlunos_if").empty();
                    for (var item in response['turma']) {

                        var linha = "";

                        console.log(response['turma'][item]['sit']);

                        if (response['turma'][item]['sit'] != "ATIVO" && response['turma'][item]['sit'] != "APROV") {
                            linha += '<tr class="red">'
                        } else {
                            linha += "<tr>"
                        }

                        linha += '<td class="text-center">' + response['turma'][item]['num_chamada'] + '</td><td class="text-center">' + response['turma'][item]['rm'] + "</td><td>" + response['turma'][item]['ra'] + "</td><td>" + response['turma'][item]['nome'] + "</td>" + "<td>" + response['turma'][item]['turma'] + "</td>";
                        

                        linha += '<td class="text-center" data-order="' + response['turma'][item]['matricula_original'] + '">' + response['turma'][item]['matricula'] + "</td>";
                        linha += '<td class="text-center" data-order="' + response['turma'][item]['fim_mat_original'] + '">' + response['turma'][item]['fim_mat'] + "</td>";
                        linha += '<td class="text-center fw-bold">' + response['turma'][item]['sit'] + "</td>";

                        linha += "</tr>";
                        $("#listaAlunos_if").append(linha);
                    }

                    let dataTable = new DataTable("#tabela_alunos_if", {
                            lengthMenu: [
                                [15, 30, 50, 100],
                                [15, 30, 50, 100],
                            ], 
                            "autoWidth": false,
                            "oLanguage": {
                                "sSearch": "Pesquisar:",
                            },
                            "language": {
                                "lengthMenu": "Exibir _MENU_ itens por página",
                                "zeroRecords": "Nada encontrado - Desculpe",
                                "info": "Exibindo _START_ até _END_ de um total de _TOTAL_ registro(s)",
                                "infoEmpty": "Sem registros",
                                "infoFiltered": "(filtrado de um total de _MAX_ registro(s))",
                                "paginate": {
                                    "previous": "Anterior",
                                    "next": "Próximo"
                                }
                            }                    
                    }); 


                },
                error: function(err) {
                    console.log(err);
                }
            });


            $("#modal_lista_turma_if").modal('show');
        }

        function consultar(id, nome, duracao, periodo, tipo_ensino) {
            $("#descTurma").text(nome);
            $("#numClasse").text(id);
            $("#descDuracao").text(duracao);
            $("#descPeriodo").text(periodo);
            $("#desc_tipo_ensino").text(tipo_ensino);

            $.ajax({
                type: "POST",
                url: "{{ url_for('getAlunosTurma') }}",
                contentType: "application/json",
                data: JSON.stringify(id),
                dataType: "json",
                success: function(response) {
                    $("#inicioTurma").text(response['duracao'][0]['inicio']);
                    $("#fimTurma").text(response['duracao'][0]['fim']);
                    $("#descTotal").html('<span class="fw-bold text-secondary">' + response['total']['ativos'] + '</span> ativos (<span class="fw-bold text-secondary">' + response['total']['total'] + ' </span>no total).');
                    
                    $("#tabelaAlunos").empty();
                    $("#tabelaAlunos").append('<table id="tabela_alunos" class="table table-hover"><thead class="table-dark"><tr><th class="text-center">Nº</th><th class="text-center">RM</th><th>RA</th><th>S</th><th>Nome</th><th class="text-center">Nascimento</th><th class="text-center">Idade</th><th class="text-center">Sexo</th><th>RG</th><th>CPF</th><th class="text-center">Matrícula</th><th class="text-center">Fim Matr.</th><th class="text-center">Situação</th></tr></thead><tbody id="listaAlunos"></tbody></table>');
                    
                    $("#listaAlunos").empty();
                    for (var item in response['turma']) {

                        var linha = "";

                        if (response['turma'][item]['sit'] != "ATIVO"  && response['turma'][item]['sit'] != "APROV") {
                            linha += '<tr class="red">'
                        } else {
                            linha += "<tr>"
                        }

                        linha += '<td class="text-center">' + response['turma'][item]['num_chamada'] + '</td><td class="text-center">' + response['turma'][item]['rm'] + "</td><td>" + response['turma'][item]['ra'] + "</td><td>" + response['turma'][item]['serie'] + "</td><td>" + response['turma'][item]['nome'] + '</td><td class="text-center" data-order="' + response['turma'][item]['nascimento_original']  + '">' + response['turma'][item]['nascimento'] + '</td><td class="text-center">' + response['turma'][item]['idade'] + '</td><td class="text-center">' + response['turma'][item]['sexo'] + "</td><td>" + response['turma'][item]['rg'] + "</td>";
                        
                        if (response['turma'][item]['cpf'] != "-") {
                            linha += "<td>" + response['turma'][item]['cpf'].replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, "$1.$2.$3-$4") + "</td>";
                        } else {
                            linha += "<td>" + response['turma'][item]['cpf'] + "</td>";
                        }

                        linha += '<td class="text-center" data-order="' + response['turma'][item]['matricula_original'] + '">' + response['turma'][item]['matricula'] + "</td>";
                        linha += '<td class="text-center" data-order="' + response['turma'][item]['fim_mat_original'] + '">' + response['turma'][item]['fim_mat'] + "</td>";
                        linha += '<td class="text-center fw-bold">' + response['turma'][item]['sit'] + "</td>";

                        linha += "</tr>";
                        $("#listaAlunos").append(linha);
                    }

                    let dataTable = new DataTable("#tabela_alunos", {
                            lengthMenu: [
                                [15, 30, 50, 100],
                                [15, 30, 50, 100],
                            ], 
                            "autoWidth": false,
                            "oLanguage": {
                                "sSearch": "Pesquisar:",
                            },
                            "language": {
                                "lengthMenu": "Exibir _MENU_ itens por página",
                                "zeroRecords": "Nada encontrado - Desculpe",
                                "info": "Exibindo _START_ até _END_ de um total de _TOTAL_ registro(s)",
                                "infoEmpty": "Sem registros",
                                "infoFiltered": "(filtrado de um total de _MAX_ registro(s))",
                                "paginate": {
                                    "previous": "Anterior",
                                    "next": "Próximo"
                                }
                            }                    
                        });                    

                },
                error: function(err) {
                    console.log(err);
                }
            });

            $("#modal_lista_turmas").modal('show');
        }

        function editar(id, nome, ensino, periodo, duracao) {
            $("#txtnumeroclasse_edit").val(id);
            $("#txtnometurma_edit").val(nome);
            $("#cbtipoensino_edit").val(ensino);
            $("#cbperiodo_edit").val(periodo);
            $("#cbduracao_edit").val(duracao);
            $("#editar_turma_modal").modal('show');
        }

        function editarIf(id, nome, ensino, periodo, duracao, categoria) {
            $("#txtnumeroclasse_if_edit").val(id);
            $("#txtnometurma_if_edit").val(nome);
            $("#cbtipoensino_if_edit").val(ensino);
            $("#cbperiodo_if_edit").val(periodo);
            $("#cbduracao_if_edit").val(duracao);
            $("#cbcategoria_if_edit").val(categoria);

            $.ajax({
                type: "POST",
                url: "{{ url_for('getVinculoIf') }}",
                contentType: "application/json",
                data: JSON.stringify(id),
                dataType: "json",
                success: function(response) {                  
                    
                    for (val in response) {
                        console.log(response[val]['num_classe_em']);
                        $('.form-check-input[value="' + response[val]['num_classe_em'] + '"]').prop("checked", true);
                    }

                },
                error: function(err) {
                    console.log(err);
                }
            });            
            

            $("#editar_itinerario_modal").modal('show');            
        }

        calendar = {{calendario}};
        //console.log(calendar);

        $("#cbduracao").on('change', function(e) {
            switch ($(this).val()) {
                case "1":
                    $("#infoinicio").text(calendar['1sem_inicio']);
                    $("#infofim").text(calendar['2sem_fim']);
                    break;
                case "2":
                    $("#infoinicio").text(calendar['1sem_inicio']);
                    $("#infofim").text(calendar['1sem_fim']);
                    break;
                case "3":
                    $("#infoinicio").text(calendar['2sem_inicio']);
                    $("#infofim").text(calendar['2sem_fim']);
                    break;                    
            }
        });

        $("#btn-importar").click(function(e) {
            window.open("https://sed.educacao.sp.gov.br/NCA/RelacaoAlunosClasse/Index", 'one');
            window.location.href = "/upload_turma?classe=" + $("#numClasse").text();
        });

        $("#btn-importar_if").click(function(e) {
            window.open("https://sed.educacao.sp.gov.br/NCA/RelacaoAlunosClasse/Index", 'one');
            window.location.href = "/upload_turma?classe=" + $("#numClasse_if").text();
        });

    </script>
  </body>
</html>