                    </div>

                    <div class="col-sm-6">
                        <div class="fw-bold">Ensino Médio EJA</div>
                       <div id="lista_geral" class="list-group">
                            {% for ensino in listaTurmas %}
                                {% if ensino['tipo_ensino']['id'] == 4 %}
                                    {% for turma in ensino['lista'] %}
                                        <li class="list-group-item"><label class="bold"><input class="form-check-input me-1" name="turmas_vinculo_if_edit" type="checkbox" value='{{turma["num_classe"]}}'>{{turma['nome_turma']}}</label></li>
                                    {% endfor %}
                                {% endif %}
                            {% endfor %}
                            
