        function capitalizeFirstLetter(string) {
            // Converte toda a string para letras minúsculas
            result = string.toLowerCase();
            
            // Divide a string em palavras, capitaliza a primeira letra de cada palavra e junta novamente
            result = result.split(' ').map(word => {
                return word.charAt(0).toUpperCase() + word.slice(1);
            }).join(' ');

            // Substitui ocorrências específicas de palavras com letras maiúsculas por minúsculas
            result = result.replaceAll(' Da ', ' da ')
                        .replaceAll(' De ', ' de ')
                        .replaceAll(' Do ', ' do ')
                        .replaceAll(' Dos ', ' dos ');
            
            return result;
        }

        function converterData(data) {
            // Verifica se a data é válida
            const partes = data.split('/'); // Divide a data em dia, mês e ano
            if (partes.length === 3) {
                const dia = partes[0];  // Dia
                const mes = partes[1];  // Mês
                const ano = partes[2];  // Ano
                
                // Retorna a data no formato yyyy-mm-dd
                return `${ano}-${mes}-${dia}`;
            } else {
                return "Data inválida!";
            }
        }           

