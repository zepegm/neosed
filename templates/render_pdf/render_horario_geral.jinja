<html>
    <head>
        <title>Rendereziação PDF</title>
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            #pagina {
                width: 729px;
                height: 1062px;
                color: black;
                margin-top: -6px;
                margin-left: -7px;
                background-color: white;
            }

            .paginas_cont {
                width: 729px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                margin-top: 30px;
                margin-left: 22px;              
            }

            #tb-principal {
                width: 100%;
                height: 100%;
                border-collapse: collapse;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 12px;
                border: 4px solid black;
            }

            #tb-principal th {
                border: 1px solid black;
                text-align: center;
                padding: 8px;
                font-family: Arial, Helvetica, sans-serif;
            }

            #tb-principal td {
                background-color: white;
                border: 1px solid black;
                text-align: center;
                /*padding: 3px;*/
                font-family: Arial, Helvetica, sans-serif;
                font-size: 11px;
            }        

            .vertical-text {
                writing-mode: vertical-rl; /* or vertical-lr */
                font-size: 25px !important;
                font-weight: bold;
                transform: rotate(180deg);
            }

            .gray {
                background-color: #e4e4e4 !important;
            }

            .d-2 {
                background-color: rgb(255, 242, 204) !important;    
            }

            .yellow {
                background-color: rgb(255, 242, 204) !important;
            }

            .d-5 {
                background-color: rgb(204, 255, 204) !important;
            }

            .first-line {
                border-top: 4px solid black !important;
            }

            .blue {
                color:white;
                background-color: #0070C0 !important;
                font-weight: bold;
                height: 2px;
                font-size: 10px !important;
            }

            .titulo {
                font-family:'BebasKai', sans-serif !important;
                font-size: 22px;
                font-weight: normal;    
                padding: 4px !important;
            }

            .red {
                color: red;
            }

            .head {
                height: 5px !important;
                padding: 4px !important;
            }

            .foot {
                text-align: left !important;
            }

            .quadrado_1 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: white; /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            .quadrado_2 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: rgb(255, 242, 204); /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            .quadrado_5 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: rgb(204, 255, 204); /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            /* disciplinas com cores específicas */

            .ELETIVA {
                background-color: rgb(254, 222, 255) !important;
            }

            .TUTORIA {
                background-color: orange !important;
            }

            .CLUBE {
                background-color: rebeccapurple !important;
                color: white;
            }    

            .ALMOÇO {
                background-color: #ff5e00 !important;
                color: white !important;
            }  

            /* professores com cores específicas */
            {% for item in profs %}
            .prof_{{item['cpf_professor']}} {
                background-color: {{item['cor']}} !important;
            }
            {% endfor %}

        </style>
    </head>
    <body>
        <div id="pagina">
            
            <table id="tb-principal">
                <thead>
                    <tr>
                        <th class="titulo" colspan="{{turmas|length + 2}}"><span class="red">Horário Geral</span> - {{tipo}} - <span class="red">{{data}}</span></th>
                    </tr>

                    <tr>
                        <th class="gray head">Dia</th>
                        <th class="gray head">Horário</th>
                        {% for item in turmas %}
                        <th class="gray head">{{item['nome_turma']}}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody> 
                    {% set count = namespace(value=0) %}

                    {% for n in range(2, 7) %}

                        {% set count.value = 0 %}
                        
                        <!-- {{dias_semana[n - 2]}} -->
                        {% for item in horario %}
                        <tr>
                            {% if loop.index == 1 %}
                                <td style="width:40px;" class="first-line gray" rowspan="{{horario|length}}"><span class="vertical-text">{{dias_semana[n - 2]}}</span></td>
                                <td style="width:80px;" class="gray first-line">{{item['horario']}}</td>

                                <!-- Agora se inicia o processo de inclusão das disciplinas -->
                                {% for turma in turmas %}
                                <td class="prof_{{grade[n][count.value]['cpf_professor']}} {{grade[n][count.value]['abv']}} first-line">{{grade[n][count.value]['abv']}} {{grade[n][count.value]['nome']}}</td>
                                {% set count.value = count.value + 1 %}
                            {% endfor %}

                            {% else %}
                                <td class="gray">{{item['horario']}}</td>

                                {% for turma in turmas %}
                                <td class="prof_{{grade[n][count.value]['cpf_professor']}} {{grade[n][count.value]['abv']}}">{{grade[n][count.value]['abv']}} {{grade[n][count.value]['nome']}}</td>
                                {% set count.value = count.value + 1 %}
                                {% endfor %}

                            {% endif %}

                        </tr>
                        {% endfor %}

                    {% endfor %}


                </tbody>

            </table>

        </div>

    </body>
</htmL>