<html>
    <head>
        <title>Rendereziação PDF</title>
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            @font-face {
                font-family:greatvibes-regular;
                font-style:normal;
                font-weight:400;
                src:local('GreatVibes-Regular'),
                url({{ url_for('static', filename='fonts/GreatVibes-Regular.woff') }}) format('woff')
            }            
             

            .blank_pag {
                width: 729px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                border-color: black;
                position: absolute;
                left: 30px;
            }            


            .pag {
                width: 699px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                border-color: black;
                position: absolute;
                /*top:2280px;*/
                left: 60px;
            }

            .capa {
                border-width: 5px;
                border-style: solid;
                border-color: black;
                position: absolute;
                top:30px;              
            }

            .capa:before {
                content: " ";
                position: absolute;
                z-index: -1;
                top: 5px;
                left: 5px;
                right: 5px;
                bottom: 5px;
                border: 1px solid black;
            } 

            .titulo {
                font-family:'BebasKai', sans-serif;
                font-size: 20px;
                text-align: center;
                /*position: absolute;
                top: 5px;
                left: 100px;*/
            }

            .blue {
                color: rgb(12, 146, 255);
            }

            .red {
                color:#DC3545;
            }

            .green {
                color:#28A745;
            }

            .head {
                border-right: black solid 1px;
                position: absolute;
                top: -1px;
                left: -1px;
                width: 480px;
                /*line-height: 0.62;*/
            }

            table, th, td {
                font-family: 'Helvetica', 'sans-serif';
                /*border: 1px solid;
                border-color: black;
                border-collapse: collapse;*/
            }

            .tb_calendar {
                border: 1px solid;
                border-color: black;
                border-collapse: collapse;

                position: relative;
                left: 0px;
                width: 481px;
                /*table-layout: fixed;*/
            }

            .tb_calendar td {
                border: 1px solid;
                border-color: black;
                border-collapse: collapse;

                font-size: 8px;
            }

            .center {
                text-align: center;
            }

            .right {
                text-align: right;
            }

            .identificador {
                position: absolute;
                font-family: Arial, Helvetica, sans-serif;
                border-right: solid black 1px;
                border-bottom: solid black 1px;
                font-size: 9px;
                width: 15px;
                height: 15px;
                top:0px;
                left:0px;
                line-height: 15px;
                text-align: center;
            }

            .tb_head {
                font-size: 12px;
                width: 100%;
            }

            .tb-head-max {
                font-size: 16px;
            }

            .txt_idf5 {
                position: relative;
            }

            .txt_idf3 {
                margin-top: 15px;
            }

            .txt_idf4 {
                margin-left: 15px;
            }            

            .vertical_text {
                writing-mode: vertical-rl;
                transform:scale(-1);
                text-orientation: mixed;
            }

            .basic-col {
                position: relative;
                text-align: center;
                height: 16px;
            }

            .fixed-col {
                width: 15px;
                text-align: center;
            }

            .right-strong-border {
                border-right: solid 2px black !important;
            }

            .gray {
                background-color: #BBBB;
            }

            .lb_secretario {
                position: absolute;
                width: 120px;
                border-top: solid 1px black;
                line-height: 1.4;
                left:50px;
            }

            .lb_diretor {
                position: absolute;
                width: 120px;
                border-top: solid 1px black;
                line-height: 1.4;    
                left:300px;            
            }

            .side_final {
                position: absolute;
                border: solid 1px black;
                top:0px;
                left: 480px;
                width: 220px;
                height: 1058px;
            }

            .head_side {
                margin-top:15px;
            }

            .txt_head_side {
                text-align: center;
                color:gray;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 14px;
                font-weight: bold;
            }

            .number_pag {
                font-family:'BebasKai', sans-serif;
                font-size: 30px;
                position: absolute;
                top: 5px;
                right: 8px;
            }

            .tb_side {
                border: solid 1px black;
                border-collapse: collapse;
                position: absolute;
                left: -1px;
                top:49px;
                /*width: 221px;
                table-layout: fixed;*/
            }

            .tb_side td, th {
                border: solid 1px black;
                border-collapse: collapse;
            }

            .cap-tit1 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                margin-top: 30px;
                font-size: 100px;
            }

            .cap-tit2 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 140px;
            }

            .logo {
                text-align: center;
                width: 100%;
                position: relative;
                top:-80px;
            }

            .cap-foot {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 80px;
                position: relative;
                top: -140px;       
            }

            .sumario {
                position: absolute;
                top: 1154px;
            }

            .sum-tit1 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 80px;
                margin-top:20px;
            }

            .sum-tit2 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 20px;   
                margin-bottom: 20px;             
            }

            .sum-col1 {
                /*border: solid 1px black;*/
                position: absolute;
                font-family: Arial, Helvetica, sans-serif;
                width: 300px;
                left: 10px;
                line-height: 11.5px;
                top: 155px;
            }

            .sum-col1 table,
            .sum-col2 table {
                width: 100%;
                border-collapse: collapse;
            }

            .row-sum {
                font-size: 12px;
                height: 22px;
                border-bottom: 1px solid black;
            }

            .sum-col2 {
                position: absolute;
                top: 155px;
                left: 380px;
                width: 300px;
            }
          
            .red-line,
            .red-line-extra,
            .red-line-extra-min {
                /*border:1px solid green;*/
                position:absolute;
                top: 303px;
                width:480px;
                height: 300px;

                background: 
                    linear-gradient(to top right,
                        rgba(220,53,69,0) 0%,
                        rgba(220,53,69,0) calc(50% - 0.8px),
                        rgba(220,53,69,1) 50%,
                        rgba(220,53,69,0) calc(50% + 0.8px),
                        rgba(220,53,69,0) 100%);
             
            }

            .red-line-extra-min {
                width: 84.38px;
            }
          

        </style>
    </head>
    <body>

        <!-- Aqui será feita a Capa -->
        <div class="pag capa">
            <div class="cap-tit1">LIVRO PONTO</div>
            <div class="cap-tit2">DOCENTE</div>
            <img class="logo" src="../static/images/Logo Neo Sed White (HQ).png">
            <div class="cap-foot red">{{data}}</div>
        </div>

        <!-- Fazer a Paginação -->
        <div class="pag sumario">
            <div class="sum-tit1">ÍNDICE</div>
            <div class="sum-tit2">ESTE LIVRO ESTÁ EM ORDEM DE RG</div>

            <div class="sum-col1">
                <table>
                    <tbody>
                        {% for n in range(0, 40) %}

                        {% if n < sumario|length %}
                        <tr style="border-bottom: 1px solid black">
                            <td class="row-sum">{{sumario[n]['professor']}}</td>
                            <td class="row-sum"><b>{{ '%02d' % sumario[n]['pag']}}</b></td>
                        </tr>
                        {% else %}
                        <tr style="border-bottom: 1px solid black">
                            <td class="row-sum">&nbsp;</td>
                            <td class="row-sum"><b>{{ '%02d' % loop.index }}</b></td>
                        </tr>
                        {% endif %}


                        {% endfor %}                
                    </tbody>
                </table>
            </div>

            <div class="sum-col2">
                <table>
                    <tbody>
                        {% for n in range(40, 80) %}
                        {% if n < sumario|length %}
                        <tr style="border-bottom: 1px solid black">
                            <td class="row-sum">{{sumario[n]['professor']}}</td>
                            <td class="row-sum"><b>{{ '%02d' % sumario[n]['pag']}}</b></td>
                        </tr>
                        {% else %}
                        <tr style="border-bottom: 1px solid black">
                            <td class="row-sum" style="width: 100%;">&nbsp;</td>
                            <td class="row-sum" width="300px"><b>{{ '%02d' % (n + 1) }}</b></td>
                        </tr>
                        {% endif %}
                        {% endfor %}                
                    </tbody>
                </table>
            </div>            

        </div>

        <!-- Aqui o Ponto será criado pegando professor por professor -->
        {% for professor in professores %}
        <div class="pag" style="top:{{professor['pos']}}px;">
            <div class="identificador">1</div>
            <div class="head">
                <div class="titulo">FREQUÊNCIA DO MÊS DE <span class="red">{{data}}</span></div>
                <table class="tb_head">
                    <tbody>
                        <tr class="tb-head-max">
                            <td class="right"><b>Nome:</b></td><td colspan="6"><u><b class="blue">{{professor['nome']}}</b></u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>RG:</b></td><td><u>{{professor['rg']}}</u></td>
                            <td class="right"><b>RS:</b></td><td colspan="2"><u>{{professor['rs']}}</u></td>
                            <td class="right"><b>CPF:</b></td><td colspan="2"><u>{{professor['cpf']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>Cargo:</b></td><td colspan="4"><u>{{professor['cargo']}}</u></td>
                            <td class="right"><b>Cat:</b></td><td colspan="2"><u>{{professor['categoria']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>{{professor['txt_sit']}}</b></td><td colspan="6"><u><span class="{{professor['class_afast']}}">{{professor['situacao']}}{{professor['atpc']}}</span></u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>Jornada:</b></td><td colspan="2"><u>{{professor['jornada']}}</u></td>
                            <td class="right" colspan="3"><b>{{professor['txt_carga']}}</b></td><td><u>{{professor['carga']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>Disciplina:</b></td><td><u>{{professor['disciplina']}}</u></td>
                            <td class="right"><b>DI: </b></td><td><u>{{professor['di']}}</u></td>
                            <td class="right" colspan="2"><b>F/N REF: </b></td><td><u>{{professor['FNREF']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right" colspan="3"><b>Sede de Classificação: </b></td><td colspan="5"><u>{{professor['sede_c']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right" colspan="3"><b>Sede de Controle de Frequência: </b></td><td colspan="5"><u>{{professor['sede_f']}}</u></td>
                        </tr>                        
                    </tbody>
                </table>

                <table class="tb_calendar">
                    <thead>
                        <tr>
                            <td rowspan="3" class="center" style="width: 84.38px;">
                                <div class="identificador">2</div>
                                ASSINATURAS
                            </td>
                            <td rowspan="2" colspan="2" class="basic-col">
                                <div class="identificador">3</div>
                                <div class="txt_idf3">Dias</div>
                            </td>
                            <td rowspan="2" colspan="4" class="basic-col right-strong-border">
                                <div class="identificador">4</div>
                                <div class="txt_idf4">Qtde. aula<br>por dia</div>
                            </td>
                            <td colspan="16" class="basic-col">
                                <div class="identificador">5</div>
                                <div class="txt_idf5 center">AUSÊNCIAS</div>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="11" class="center right-strong-border">Nesta Unidade Escolar</td>
                            <td colspan="3" class="center right-strong-border">Total</td>
                            <td class="vertical_text center fixed-col" rowspan="2">NATUREZA (TIPO) DA FALTA</td>
                            <td class="vertical_text center fixed-col" rowspan="2">FALTA MÉDICA PARCIAL</td>
                        </tr>

                        <tr>
                            <td class="vertical_text center fixed-col">DIA DO MÊS</td>
                            <td class="vertical_text center fixed-col">DIA DA SEMANA</td>
                            <td class="vertical_text center fixed-col">AULAS NESTA U.E. (SCF)</td>
                            <td class="vertical_text center fixed-col">AULAS EM OUTRAS U.E.s</td>
                            <td class="vertical_text center fixed-col" style="font-size: 7px">SUBSTITUIÇÃO EVENTUAL</td>
                            <td class="vertical_text center fixed-col right-strong-border">TOTAL GERAL</td>


                            {% for i in range(1, 11) %}
                            <td class="fixed-col">{{i}}ª</td>
                            {% endfor %}

                            <td class="fixed-col right-strong-border">11ª</td>

                            <td class="vertical_text center fixed-col">U.E. LOCAL</td>
                            <td class="vertical_text center fixed-col">OUTRAS  U.E.s</td>
                            <td class="vertical_text center fixed-col right-strong-border">GERAL</td>

                        </tr>

                    </thead>
                    <tbody>
                        {% for dia in professor['dias'] %}
                        {% if professor['assina_livro'] == 1 %}
                        <tr class="center {{dia['class-bg']}}" style="height: 16px;">
                        {% else %}
                        <tr class="center gray" style="height: 16px;">
                        {% endif %}
                            {% if professor['assina_livro'] == 1 %}
                            <td class="red txt-assinatura">{{dia['Assinatura']}}</td>
                            {% else %}
                            <td class="red txt-assinatura"></td>
                            {% endif %}
                            <td class="{{dia['class-txt']}}">{{dia['dia']}}</td>
                            <td class="{{dia['class-txt']}}">{{dia['semana']}}</td>

                            {% if professor['qtd_aulas_semanais'][dia['semana']] > 0 and dia['evento'] == 0 and professor['assina_livro'] == 1 %}
                            <td class="blue">{{professor['qtd_aulas_semanais'][dia['semana']]}}</td>
                            {% else %}
                            <td></td>
                            {% endif %}

                            <td></td><td></td>

                            {% if professor['qtd_aulas_semanais'][dia['semana']] > 0 and dia['evento'] == 0 and professor['assina_livro'] == 1 %}
                            <td class="blue right-strong-border">{{professor['qtd_aulas_semanais'][dia['semana']]}}</td>
                            {% else %}
                            <td class = 'right-strong-border'></td>
                            {% endif %}   

                            {% for n in range(10) %}
                            <td></td>
                            {% endfor %}

                            <td class="right-strong-border"></td>

                            <td></td><td></td><td class="right-strong-border"></td>

                            <td></td><td></td>

                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="23" class="center basic-col">
                                <div class="identificador">6</div>
                                OBSERVAÇÕES
                            </td>
                        </tr>

                        <!-- Preencher o resto das lacunas do campo observação -->
                        {% for n in range(linhas) %}
                        <tr><td style="text-align: left; height: 16px;" colspan="23" class="red basic-col">{{professor['eventos'][n]}}</td></tr>
                        {% endfor %}

                        {% for n in range(4) %}
                            {% if professor['quadro']|length > 0 %}
                            <tr class="center">
                                <td colspan="11"></td>
                                <td class="gray" colspan="6" style="height: 16px;">{{professor['quadro'][n]['col1']}}</td>
                                {% if n == 0 %}
                                <td class="gray" colspan="3" style="height: 16px;">{{professor['quadro'][n]['col2']}}</td>
                                <td class="gray" colspan="4" style="height: 16px;">{{professor['quadro'][n]['col3']}}</td>
                                {% else %}
                                <td colspan="3" style="height: 16px;">{{professor['quadro'][n]['col2']}}</td>
                                <td colspan="4" style="height: 16px;">{{professor['quadro'][n]['col3']}}</td>
                                {% endif %}
                            </tr>
                            {% else %}
                            <tr><td colspan="23" style="height: 16px;">&nbsp;</td></tr>
                            {% endif %}
                        {% endfor %}

                        <!-- Campo Assinatura Final -->
                        <tr>
                            <td colspan="23" class="center basic-col" style="height: 116.1px; border-bottom: none">
                                <div class="identificador">7</div>
                                <div class="lb_secretario">
                                    {{info_assinatura['secretario']}}<br>
                                    RG: {{info_assinatura['rg_secretario']}}<br>
                                    {{info_assinatura['cargo_secretario']}}
                                </div>
                                <div class="lb_diretor">
                                    {{info_assinatura['diretor']}}<br>
                                    RG: {{info_assinatura['rg_diretor']}}<br>
                                    Diretor de Escola
                                </div>                                
                            </td>
                        </tr>                        
                    </tfoot>
                </table>


                <!-- Verificar se o professor assina o livro -->
                {% if professor['assina_livro'] == 0 %}
                <div class="red-line"></div>
                {% endif %}
                {{professor['extra_red']}}

                <!-- Basta agora apenas inserir as informações no lado direito da folha onde consta o quadro de aulas -->
                <div class="side_final">
                    <div class="head_side">
                        <div class="txt_head_side">ORDEM POR RG</div>
                        {% if folha_extra > 0 %}
                        <div class="number_pag">{{ '%02d' % folha_extra}}</div>
                        {% else %}
                        <div class="number_pag">{{ '%02d' % loop.index}}</div>
                        {% endif %}
                    </div>
                    <table class="tb_side">
                        <thead>
                            <tr>
                                <th style="border-bottom:2px solid black;border-top:2px solid black;" colspan="9" class="center">
                                    <div class="identificador">8</div>
                                    <span>HORÁRIO</span>
                                </th>
                            </tr>
                            <tr class="center" style="font-size:8px;border-bottom:2px solid black;">
                                <td>Períodos e Aulas</td>
                                <td style="width: 47px;min-width:47px;max-width:47px;border-right: 2px solid black;">Início e Término</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Seg</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Ter</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Qua</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Qui</td>
                                <td style="width: 16px;min-width:16px;max-width:16px;border-right: 2px solid black;">Sex</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Sab</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Dom</td>
                            </tr>
                        </thead>
                        <tbody>
                        {% for n in range(48) %}
                        <tr style="font-size:6px;height: 16px;">
                            {% if n < professor['quadro_aula']|length %}
                                <td class="center">{{professor['quadro_aula'][n]['periodo']}}</td>
                                <td style="border-right: 2px solid black;" class="center">{{professor['quadro_aula'][n]['horario']}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['seg'] | replace("SLN","SL")}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['ter'] | replace("SLN","SL")}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['qua'] | replace("SLN","SL")}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['qui'] | replace("SLN","SL")}}</td>
                                <td style="border-right: 2px solid black;" class="center green">{{professor['quadro_aula'][n]['sex']}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['sab'] | replace("SLN","SL")}}</td>
                                <td class="center green">{{professor['quadro_aula'][n]['dom'] | replace("SLN","SL")}}</td>
                            {% else %}
                                <td></td>
                                <td style="border-right: 2px solid black;"></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td style="border-right: 2px solid black;"></td>
                                <td></td>
                                <td></td>
                            {% endif %}
                        </tr>
                        {% endfor %}

                        <!-- Colocar o total geral -->
                        <tr style="font-size:7px;" class="gray center">
                            <td style="height: 16px;border-right: 2px solid black;" colspan="2" class="gray"></td>
                            <td>Seg</td><td>Ter</td><td>Qua</td><td>Qui</td><td style="border-right: 2px solid black;">Sex</td><td>Sáb</td><td>Dom</td>
                        </tr>

                        <tr style="font-size:8px;text-align: right;">
                            <td style="height: 16px;border-right: 2px solid black;" colspan="2" class="gray"><b>Total:</b></td>

                            {% for dia in dias_semana %}
                                {% if professor['qtd_aulas_semanais'][dia] > 0 %}
                                    {% if dia == 'sex' %}
                                    <td class="center gray" style="font-size:10px;border-right: 2px solid black;">{{professor['qtd_aulas_semanais'][dia]}}</td>
                                    {% else %}
                                    <td class="center gray" style="font-size:10px;">{{professor['qtd_aulas_semanais'][dia]}}</td>
                                    {% endif %}
                                {% else %}
                                    {% if dia == 'sex' %}
                                    <td class="gray" style="border-right: 2px solid black;"></td>
                                    {% else %}
                                    <td class="gray"></td>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
      
                        </tr>

                        </tbody>
                        <tfoot>
                            <tr><td colspan="10" style="height: 16px;"></td></tr>
                            <tr>
                                <th style="border-bottom:2px solid black;border-top:2px solid black;position: relative;" colspan="9" class="center">
                                    <div class="identificador">9</div>
                                    <span>CARGA OUTRAS UEs</span>
                                </th>
                            </tr>
                            <tr style="font-size:7px;" class="center">
                                <td style="height: 16px;border-right: 2px solid black;" colspan="2"></td>
                                <td>Seg</td><td>Ter</td><td>Qua</td><td>Qui</td><td style="border-right: 2px solid black;">Sex</td><td>Sáb</td><td>Dom</td>
                            </tr>
                            <tr style="font-size:10px;border-bottom: solid black 2px;">
                                <td colspan="2" style="height: 16px;font-size:8px;text-align:right;font-weight: bold;border-right: 2px solid black;">Qtd. de Aulas:</td>
                                <td class="center">{{professor['aulas_ue']['seg']}}</td>
                                <td class="center">{{professor['aulas_ue']['ter']}}</td>
                                <td class="center">{{professor['aulas_ue']['qua']}}</td>
