<html>
    <head>
        <title>Rendereziação PDF</title>
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            @font-face {
                font-family:greatvibes-regular;
                font-style:normal;
                font-weight:400;
                src:local('GreatVibes-Regular'),
                url({{ url_for('static', filename='fonts/GreatVibes-Regular.woff') }}) format('woff')
            }            
             

            .blank_pag {
                width: 729px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                border-color: black;
                position: absolute;
                left: 30px;
            }            


            .pag {
                width: 699px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                border-color: black;
                position: absolute;
                /*top:2280px;*/
                left: 60px;
            }



            .titulo {
                font-family:'BebasKai', sans-serif;
                font-size: 20px;
                text-align: center;
                /*position: absolute;
                top: 5px;
                left: 100px;*/
            }

            .blue {
                color: rgb(12, 146, 255);
            }

            .red {
                color:red;
            }

            .head {
                border: black solid 1px;
                position: absolute;
                top: -1px;
                left: -1px;
                width: 480px;
                /*line-height: 0.62;*/
            }

            table, th, td {
                font-family: 'Helvetica', 'sans-serif';
                /*border: 1px solid;
                border-color: black;
                border-collapse: collapse;*/
            }

            .center {
                text-align: center;
            }

            .right {
                text-align: right;
            }

            .identificador {
                font-family: Arial, Helvetica, sans-serif;
                border: solid black 1px;
                font-size: 9px;
                width: 15px;
                height: 15px;
                top:-1px;
                left: -1px;;
                position: absolute;

                line-height: 15px;
                text-align: center;                
            }

            .tb_head {
                font-size: 14px;
                width: 100%;
            }


        </style>
    </head>
    <body>
        {% for professor in professores %}
        <div class="pag" style="top:{{professor['pos']}}px;">
            <div class="identificador">1</div>
            <div class="head">
                <div class="titulo">FREQUÊNCIA DO MÊS DE <span class="red">{{data}}</span></div>
                <table class="tb_head">
                    <tbody>
                        <tr>
                            <td class="right"><b>Nome:</b></td><td colspan="5">{{professor['nome']}}</td>
                            <td class="right"><b>DI:</b></td><td>{{professor['di']}}</td>
                        </tr>
                        <tr>
                            <td class="right"><b>RG:</b></td><td>{{professor['rg']}}</td>
                            <td class="right"><b>RS:</b></td><td colspan="2">{{professor['rs']}}</td>
                            <td class="right"><b>CPF:</b></td><td colspan="2">{{professor['cpf']}}</td>
                        </tr>
                        <tr>
                            <td class="right"><b>Cargo:</b></td><td colspan="4">{{professor['cargo']}}</td>
                            <td class="right"><b>Cat:</b></td><td colspan="2">{{professor['categoria']}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        {% endfor %}
    </body>

    <script src="{{ url_for('static', filename='js/jquery-3.7.0.min.js') }}"></script> 
    <script>

    </script>
</html>