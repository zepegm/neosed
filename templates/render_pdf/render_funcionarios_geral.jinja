<html>
    <head>
        <title>Rendereziação PDF</title>
        <link href="{{ url_for('static', filename='stylesheets/print-default.css') }}" rel="stylesheet">
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            @media print {
                @page {
                    size: A4 landscape !important;
                    margin: 10mm;
                }
            }

            .pagina {
                width: 1064px;
                border-width: 2px;
                border-style: solid;
                padding:10mm;
                
                color: black;
                /*padding-top: 27px;*/
                margin-left: -7px;
                background-color: white;
            }

            .tb-principal {
                width: 100%;
                border-collapse: collapse;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 14px;
                border: 4px solid black;
                border:solid 2px black;
            }

            .tb-principal td, th {
                border: solid 1px black;
                text-align: left;
                padding-left: 1vw;
                min-width: 30px;
            }

            .titulo {
                font-size: 15px;
                font-weight: bold;    
                padding: 4px !important;
                background-color: rgb(254, 255, 178);
                border: solid 2px black;
            }

            .subtitulo {
                background-color: rgb(255, 255, 229);
                border-bottom: 2px solid black;
            }

            .text-center {
                text-align: center !important;
                padding-left: 0 !important;
            }

            table tbody tr:nth-child(even) {
                background-color: #f2f2f2; /* Cor cinza clara similar ao Bootstrap */
            }



        </style>
    </head>
    <body>

        <div id="loading">
            <div class="loader"></div>
            <p id="progresso-texto">Preparando PDF...</p>
            <!-- <div id="barra-container">
            <div id="barra"></div> -->
            </div>    
        </div>

        <button class="btn no-print" onclick="window.print()">Imprimir</button>

        <div class="pagina">
            <table class="tb-principal table table-striped table-bordered">
                <thead class="table-warning">
                    <tr>
                        <th colspan="9" class="text-center titulo">{{titulos[0]}}</th>
                    </tr>
                    <tr>
                        <th class="subtitulo">Nome</th>
                        <th class="subtitulo text-center">RG</th>
                        <th class="subtitulo text-center">CPF</th>
                        <th class="text-center subtitulo">DI</th>
                        <th class="text-center subtitulo">Nascimento</th>
                        <th class="text-center subtitulo">Cat.</th>
                        <th class="text-center subtitulo">Cargo</th>
                        <th class="text-center subtitulo">RS/PV</th>
                        <th class="text-center subtitulo">F/N</th>
                    </tr>
                </thead>            
            {% for item in titulos %}
                {% if loop.index > 1%}
                <thead>
                    <tr>
                        <th colspan="9" class="text-center titulo">{{item}}</th>
                    </tr>
                </thead>
                {% endif %}
                <tbody>
                    {% for item in lista_final[loop.index - 1] %}
                    <tr>
                        <td>{{item['nome']}}</td>
                        <td class="text-center">{{item['rg']}}</td>
                        <td class="text-center">{{item['cpf']}}</td>
                        <td class="text-center">{{item['di']}}</td>
                        <td class="text-center">{{item['nascimento']}}</td>
                        <td class="text-center">{{item['categoria']}}</td>
                        <td class="text-center">{{item['abv']}}</td>
                        <td class="text-center">{{item['rs']}}/{{item['pv']}}</td>
                        <td class="text-center">{{item['FNREF']}}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            {% endfor %}
            </table>
        </div>
        <script src="{{ url_for('static', filename='js/print-default.js') }}"></script> 
    </body>
</htmL>