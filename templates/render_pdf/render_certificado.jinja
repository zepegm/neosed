<html lang="pt-BR">
    <title>Render Certificado</title>
    <link href="{{ url_for('static', filename='stylesheets/print-default.css') }}" rel="stylesheet">
    <style>
        .pagina {
            width: 1106px;
            height: 768px;
            border: solid 1px white;
            background-image: url("static/images/Certificado.png");
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            position: relative;
            top:0;
            margin-bottom: 0;
            break-before: page; /* Força quebra antes do elemento */
        }

        @media print {
            @page {
                size: A4 landscape !important;
            }
        }        
        
        .texto {
            position: relative;
            top: 460px;
            left: 100px;
            width: 900px;
            text-align: justify;
            text-justify: inter-word;
            font-size: 20px;
            line-height: 35px;
        }

        .assinatura {
            text-align: center;
            position: relative;
            top: 495px;
            left: 100px;
            width: 900px;
        }

        .data {
            font-size: 20px;
            font-style: italic;
            text-align: right;
            position: relative;
            top: 460px;
            right: 110px;
        }

    </style>
    <body>

        <div id="loading">
            <div class="loader"></div>
            <p id="progresso-texto">Preparando PDF...</p>
            <!-- <div id="barra-container">
            <div id="barra"></div> -->
            </div>    
        </div>

        <button class="btn no-print" onclick="window.print()">Imprimir</button>   

        {% for aluno in alunos %}
        <div class="pagina">
            <div class="texto">{{aluno['texto_final']}}</div>
            <div class="data">Cruzeiro, {{aluno['fim']}}</div>
            <table class="assinatura">
                <tr>
                    <td>______________________________<br>Concluinte<br>{{aluno['nome_assinatura']}}<br>{{aluno['rg']}}</td>
                    <td>______________________________<br>Vice-Diretor de Escola<br>{{nome_vice}}<br>{{rg_vice}}</td>
                    <td>______________________________<br>Diretor de Escola<br>{{nome_diretor}}<br>{{rg_diretor}}</td>
                </tr>
            </table>
        </div>
        {% endfor %}
        <script src="{{ url_for('static', filename='js/print-default.js') }}"></script>
    </body>
</html>