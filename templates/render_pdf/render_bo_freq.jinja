                                <td>Seg</td><td>Ter</td><td>Qua</td><td>Qui</td><td style="border-right: 2px solid black;">Sex</td><td>Sáb</td><td>Dom</td>
                            </tr>
                            <tr style="font-size:10px;border-bottom: solid black 2px;">
                                <td colspan="2" style="height: 16px;font-size:8px;text-align:right;font-weight: bold;border-right: 2px solid black;">Qtd. de Aulas:</td>
                                <td class="center">{{professor['total_geral']['seg']}}</td>
                                <td class="center">{{professor['total_geral']['ter']}}</td>
                                <td class="center">{{professor['total_geral']['qua']}}</td>
                                <td class="center">{{professor['total_geral']['qui']}}</td>
                                <td class="center" style="border-right: 2px solid black;">{{professor['total_geral']['sex']}}</td>
                                <td class="center">{{professor['total_geral']['sáb']}}</td>
                                <td class="center">{{professor['total_geral']['dom']}}</td>
                            </tr>

                        </tfoot>
                    </table>
                </div>

            </div>
        </div>
        {% endfor %}
        <script src="{{ url_for('static', filename='js/print-default.js') }}"></script>
