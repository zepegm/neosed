                                <td class="center">{{professor['aulas_ue']['seg']}}</td>
                                <td class="center">{{professor['aulas_ue']['ter']}}</td>
                                <td class="center">{{professor['aulas_ue']['qua']}}</td>
                                <td class="center">{{professor['aulas_ue']['qui']}}</td>
                                <td class="center" style="border-right: 2px solid black;">{{professor['aulas_ue']['sex']}}</td>
                                <td class="center">{{professor['aulas_ue']['sáb']}}</td>
                                <td class="center">{{professor['aulas_ue']['dom']}}</td>
                            </tr>

                            <!-- TOTAL GERAL, para finalizar isso de uma vez por todas -->
                            <tr><td colspan="10" style="height: 16px;"></td></tr>
                            <tr>
