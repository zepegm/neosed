<html>
    <head>
        <title>Rendereziação PDF</title>
        <link href="{{ url_for('static', filename='stylesheets/print-default.css') }}" rel="stylesheet">
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            @font-face {
                font-family:greatvibes-regular;
                font-style:normal;
                font-weight:400;
                src:local('GreatVibes-Regular'),
                url({{ url_for('static', filename='fonts/GreatVibes-Regular.woff') }}) format('woff')
            }            
             

            .blank_pag {
                width: 729px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                border-color: black;
                position: absolute;
                left: 30px;
            }            


            .pag {
                /*width: 588px;
                height: 1057px;*/
                border-width: 2px;
                border-style: solid;
                border-color: white;
                position: relative;
                margin-left: 125px;
                padding: 0;
                break-before: page !important; /* Força quebra antes do elemento */
            }

            .sumario {
                margin-top: 5mm;
            }

            .capa {
                border-width: 5px;
                border-style: solid;
                border-color: black;
                /*position: absolute;
                top:30px;*/
            }

            .capa:before {
                content: " ";
                position: absolute;
                z-index: -1;
                top: 5px;
                left: 5px;
                right: 5px;
                bottom: 5px;
                border: 1px solid black;
            } 

            .titulo {
                font-family:'BebasKai', sans-serif;
                font-size: 20px;
                text-align: center;
                /*position: absolute;
                top: 5px;
                left: 100px;*/
            }

            .blue {
                color: rgb(12, 146, 255);
            }

            .red {
                color:#DC3545;
            }

            .green {
                color:#28A745;
            }

            .head {
                border-right: black solid 2px;
                border-top: black solid 2px;
                border-left: black solid 2px;
                position: absolute;
                top: -1px;
                left: -1px;
                /*width: 370px;*/
                /*line-height: 0.62;*/
            }

            table, th, td {
                font-family: 'Helvetica', 'sans-serif';
                /*border: 1px solid;
                border-color: black;
                border-collapse: collapse;*/
            }

            .tb_calendar {
                border: none !important;
                border-collapse: collapse;

                position: relative;
                left: 0px;
                /*width: 370px;
                /*table-layout: fixed;*/
            }

            .tb_calendar td {
                border: 1px solid;
                border-color: black;
                border-collapse: collapse;

                font-size: 8px;
            }

            .center {
                text-align: center;
            }

            .right {
                text-align: right;
            }

            .identificador {
                position: absolute;
                font-family: Arial, Helvetica, sans-serif;
                border-right: solid black 1px;
                border-bottom: solid black 1px;
                font-size: 9px;
                width: 15px;
                height: 15px;
                top:0px;
                left:0px;
                line-height: 15px;
                text-align: center;
            }

            .tb_head {
                font-size: 12px;
                width: 100%;
            }

            .tb-head-max {
                font-size: 16px;
            }

            .txt_idf5 {
                position: relative;
            }

            .txt_idf3 {
                margin-top: 7px;
                margin-bottom: 7px;
                font-weight: bold;
                font-size:9px;
            }

            .txt_idf4 {
                margin-left: 15px;
            }            

            .vertical_text {
                writing-mode: vertical-rl;
                transform:scale(-1);
                text-orientation: mixed;
            }

            .basic-col {
                position: relative;
                text-align: center;
                height: 16px;
            }

            .fixed-col {
                width: 25px;
                text-align: center;
            }

            .fixed-col-2 {
                width: 15px;
                text-align: center;
            }

            .right-strong-border {
                border-right: solid 2px black !important;
            }

            .gray {
                background-color: #BBBB;
            }

            .lb_secretario {
                position: relative;
                width: 80px;
                border-bottom: solid 1px black;
                line-height: 1.4;
                left:50px;
            }

            .lb_recebi {
                position: relative;
                width: 80px;
                line-height: 1.4;
                left:50px;
                margin-top:35px;
            }

            .lb_diretor {
                position: absolute;
                width: 120px;
                border-top: solid 1px black;
                line-height: 1.4;    
                left:300px;            
            }

            .side_final {
                position: absolute;
                border: solid 1px black;
                top:0px;
                left: 369px;
                width: 220px;
                height: 1058px;
                display:none;
            }

            .head_side {
                margin-top:15px;
            }

            .txt_head_side {
                text-align: center;
                color:gray;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 14px;
                font-weight: bold;
            }

            .number_pag {
                font-family:'BebasKai', sans-serif;
                font-size: 30px;
                position: absolute;
                top: 5px;
                right: 8px;
            }

            .tb_side {
                border: solid 1px black;
                border-collapse: collapse;
                position: absolute;
                left: -1px;
                top:49px;
                /*width: 221px;
                table-layout: fixed;*/
            }

            .tb_side td, th {
                border: solid 1px black;
                border-collapse: collapse;
            }

            .cap-tit1 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                margin-top: 30px;
                font-size: 100px;
            }

            .cap-tit2 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 140px;
            }

            .logo {
                text-align: center;
                width: 100%;
                position: relative;
                top:-80px;
            }

            .cap-foot {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 80px;
                position: relative;
                top: -140px;       
            }

            .sum-tit1 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 80px;
                margin-top:20px;
            }

            .sum-tit2 {
                font-family: 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
                text-align: center;
                font-size: 20px;   
                margin-bottom: 20px;             
            }

            .sum-col1 {
                /*border: solid 1px black;*/
                position: absolute;
                font-family: Arial, Helvetica, sans-serif;
                width: 300px;
                left: 10px;
                line-height: 11.5px;
                top: 155px;
            }

            .sum-col1 table,
            .sum-col2 table {
                width: 100%;
                border-collapse: collapse;
            }

            .row-sum {
                font-size: 12px;
                height: 22px;
                border-bottom: 1px solid black;
            }

            .sum-col2 {
                position: absolute;
                top: 155px;
                left: 380px;
                width: 300px;
            }
          
            .red-line,
            .red-line-extra,
            .red-line-extra-min {
                /*border:1px solid green;*/
                position:absolute;
                top: 303px;
                width:480px;
                height: 300px;

                background: 
                    linear-gradient(to top right,
                        rgba(220,53,69,0) 0%,
                        rgba(220,53,69,0) calc(50% - 0.8px),
                        rgba(220,53,69,1) 50%,
                        rgba(220,53,69,0) calc(50% + 0.8px),
                        rgba(220,53,69,0) 100%);
             
            }

            .red-line-extra-min {
                width: 84.38px;
            }

            .blank-line {
                border-bottom:1px solid #BBB !important;
            }
          

        </style>
    </head>
    <body>

        <div id="loading">
            <div class="loader"></div>
            <p id="progresso-texto">Preparando PDF...</p>
            <!-- <div id="barra-container">
            <div id="barra"></div> -->
            </div>    
        </div>

        <button class="btn no-print" onclick="window.print()">Imprimir</button>      

        <!-- Aqui o Ponto será criado pegando professor por professor -->
        {% for professor in professores %}
        <div class="pag" style="break-before: page !important; margin-top: 5mm;">
            <div class="identificador">1</div>
            <div class="head">
                <div class="titulo">BOLETIM DE OCORRÊNCIAS - B.O. - <span class="red">{{data}}</span></div>
                <table class="tb_head">
                    <tbody>
                        <tr class="tb-head-max">
                            <td class="right"><b>Nome:</b></td><td colspan="6"><u><b class="blue">{{professor['nome']}}</b></u></td>
                        </tr>
                        <tr>
                            {% if professor['rg'] == '00.000.000-0' %}
                            <td class="right"><b>CIN:</b></td><td><u>{{professor['cpf']}}</u></td>
                            {% else %}
                            <td class="right"><b>RG:</b></td><td><u>{{professor['rg']}}</u></td>
                            {% endif %}
                        </tr>
                        <tr>
                            <td class="right"><b>Cargo:</b></td><td colspan="4"><u>{{professor['cargo']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>Cat:</b></td><td colspan="2"><u>{{professor['categoria']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>{{professor['txt_sit']}}</b></td><td colspan="6"><u><span class="{{professor['class_afast']}}">{{professor['situacao']}}{{professor['atpc']}}</span></u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>DI:</b></td><td colspan="2"><u>{{professor['di']}}</u></td>
                        </tr>
                        <tr>
                            <td class="right"><b>UA Sede:</b></td><td><u>{{professor['sede_c']}}</u></td>
                        </tr>
                    </tbody>
                </table>

                <table class="tb_calendar">
                    <thead>
                        <tr>
                            <td colspan="6" class="center right-strong-border" style="width: 84.38px;border-left:none;">
                                <div class="identificador">2</div>
                                <div class="center txt_idf3">Jornada Prevista U.E.</div>
                            </td>
                            <td colspan="2" colspan="2" class="basic-col right-strong-border">
                                <div class="identificador">3</div>
                                <div class="center" style="margin-top:15px; font-weight: bold;">Ausências</div>
                            </td>
                            <td colspan="9" class="basic-col" style="border-right: none;">
                                <div class="identificador">4</div>
                                <div class="center txt_idf3">Horário</div>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="2" class="center" style="border-left:none;">Dias</td>
                            <td class="vertical_text center fixed-col" rowspan="7">Funções<br>Remuneradas</td>
                            <td class="vertical_text center fixed-col" rowspan="7">Substituições</td>
                            <td class="vertical_text center fixed-col" rowspan="7">Recup. / Repos.</td>
                            <td class="vertical_text center fixed-col right-strong-border" rowspan="7">Total Geral</td>
                            <td class="vertical_text center fixed-col" rowspan="7">Horas-Aula</td>
                            <td class="vertical_text center fixed-col right-strong-border" rowspan="7">Natureza</td>
                            <td class="center">Períodos<br>e Aulas</td>
                            <td class="center" style="width:50px;">Início e<br>Término</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Seg</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Ter</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Qua</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Qui</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Sex</td>
                            <td class="center fixed-col-2" style="font-size:7px;">Sáb</td>
                            <td class="center fixed-col-2" style="border-right: none; font-size:7px;">Dom</td>
                        </tr>

                        <tr>
                            <td class="vertical_text center fixed-col" rowspan="6" style="border-left:none;">DIA DO MÊS</td>
                            <td class="vertical_text center fixed-col" rowspan="6">DIA DA SEMANA</td>
                        </tr>

                        <!-- Desenhar Início do Horário -->
                        {% for n in range(5) %}
                        <tr style="font-size:6px;height: 16px;">
                            {% if n < professor['quadro_aula']|length %}
                            <td style="font-size:6px;" class="center">{{professor['quadro_aula'][n]['periodo']}}</td>
                            <td style="font-size:6px;" class="center">{{professor['quadro_aula'][n]['horario']}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['seg'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['ter'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['qua'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['qui'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['sex'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px;" class="center green">{{professor['quadro_aula'][n]['sab'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; border-right: none;" class="center green">{{professor['quadro_aula'][n]['dom'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            {% else %}
                            <td style="font-size:6px;" class="center">-</td>
                            <td style="font-size:6px;" class="center">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="font-size:6px;" class="center green">-</td>
                            <td style="border-right: none;" class="center green">-</td>
                            {% endif %}
                        </tr>
                        {% endfor %}

                    </thead>
                    <tbody>

                        {% set ns = namespace(contador=5, total = 0) %}

                        {% for dia in professor['dias'] %}
                        {% if professor['assina_livro'] == 1 %}
                        <tr class="center {{dia['class-bg']}}" style="height: 16px;">
                        {% else %}
                        <tr class="center gray" style="height: 16px;">
                        {% endif %}
                            <td class="{{dia['class-txt']}}" style="border-left:none;">{{dia['dia']}}</td>
                            <td class="{{dia['class-txt']}}">{{dia['semana']}}</td>

                            {% if professor['qtd_aulas_semanais'][dia['semana']] > 0 and dia['evento'] == 0 and professor['assina_livro'] == 1 %}
                            <td class="blue">{{professor['qtd_aulas_semanais'][dia['semana']]}}</td><td></td><td></td>
                            {% elif dia['evento'] > 0 %}
                            <td colspan="4" class="right-strong-border">{{dia['Assinatura']}}</td>
                            {% elif dia['class-bg'] == 'gray' %}
                            <td colspan="4" class="right-strong-border"></td>
                            {% else %}
                            <td></td><td></td><td></td>
                            {% endif %}

                            {% if professor['qtd_aulas_semanais'][dia['semana']] > 0 and dia['evento'] == 0 and professor['assina_livro'] == 1 and dia['evento'] == 0 and dia['class-bg'] != 'gray' %}
                            <td class="blue right-strong-border">{{professor['qtd_aulas_semanais'][dia['semana']]}}</td>
                            {% elif dia['evento'] == 0 and dia['class-bg'] != 'gray' %}
                            <td class = 'right-strong-border'></td>
                            {% endif %}

                            <td class="red" contenteditable="true"></td>
                            <td class="red right-strong-border" contenteditable="true"></td>

                            {% if professor['quadro_aula']|length > 5 and ns.contador < professor['quadro_aula']|length %}
                            <td style="font-size:6px; background-color:white;" class="center">{{professor['quadro_aula'][ns.contador]['periodo']}}</td>
                            <td style="font-size:6px; background-color:white;" class="center">{{professor['quadro_aula'][ns.contador]['horario']}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['seg'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['ter'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['qua'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['qui'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['sex'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['sab'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>
                            <td style="font-size:6px; border-right: none; background-color:white;" class="center green">{{professor['quadro_aula'][ns.contador]['dom'] | replace("SLN","SL") | replace("INV","") | replace("REAN","REA") | replace("PATN","PAT")}}</td>                            
                            {% set ns.contador = ns.contador + 1 %}
                            {% elif ns.total == 0 %}
                            <td colspan="2" style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">Total de Aulas:</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['seg']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['ter']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['qua']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['qui']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['sex']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold;" class="center">{{professor['total_geral']['sab']}}</td>
                            <td style="border-top: 2px solid black; border-bottom: 2px solid black; font-size:8px; background-color:rgb(239, 246, 255); font-weight: bold; border-right: none;" class="center">{{professor['total_geral']['dom']}}</td>
                            {% set ns.total = 1 %}
                            {% else %}
                            <td colspan="9" style="background-color:#BBB; !important; border-bottom:solid 1px #BBB;border-right: none;"></td>
                            {% endif %}

                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="23" class="center basic-col" style="border-left:none; border-top: 2px solid black; border-right: none;">
                                <div class="identificador" style="border-bottom:none;">5</div>
                                OBSERVAÇÕES
                            </td>
                        </tr>

                        <!-- Preencher o resto das lacunas do campo observação -->
                        {% for evento in professor['eventos'] %}
                        <tr><td style="text-align: left; height: 16px; border-right: none; border-left:none; font-size:8px;" colspan="17" class="red basic-col">{{evento}}</td></tr>
                        {% endfor %}

                        {% for n in range(linhas) %}
                        <tr><td colspan="17" style="text-align: left; height: 16px; border-right: none; border-left:none; font-size:8px;">&nbsp;</td></tr>
                        {% endfor %}

                        <!-- Campo Assinatura Final -->
                        <tr>
                            <td colspan="8" class="center basic-col" style="border-bottom: 2px solid black !important; border-left:none; height: 90px; border-bottom: none; border-right: none;">
                                <div class="identificador">6</div>
                                <div class="lb_secretario" style="font-weight: bold;">
                                    {{ data_hoje }}
                                </div>
                                <div class="lb_recebi">
                                    Recebi em: _____/_____/_____.
                                </div>                                
                            </td>
                            <td colspan="5" class="center" style="border:none; border-bottom: 2px solid black;">
                                <div style="border-top:1px solid black">Assinatura do responsável</div>
                            </td>
                            <td colspan="4" style="border-bottom: 2px solid black; border-right: none; border-left:none;"></td>
                        </tr>                       
                    </tfoot>
                </table>


                <!-- Verificar se o professor assina o livro -->
                {% if professor['assina_livro'] == 0 %}
                <div class="red-line"></div>
                {% endif %}
                {{professor['extra_red']}}

                <!-- Basta agora apenas inserir as informações no lado direito da folha onde consta o quadro de aulas -->
                <div class="side_final">
                    <div class="head_side">
                        <div class="txt_head_side">EE MAJOR HERMÓGENES</div>
                    </div>
                    <table class="tb_side">
                        <thead>
                            <tr>
                                <th style="border-bottom:2px solid black;border-top:2px solid black;" colspan="9" class="center">
                                    <div class="identificador">4</div>
                                    <span>HORÁRIO</span>
                                </th>
                            </tr>
                            <tr class="center" style="font-size:8px;border-bottom:2px solid black;">
                                <td>Períodos e Aulas</td>
                                <td style="width: 100px;min-width:54px;max-width:47px;border-right: 2px solid black;">Início e Término</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Seg</td>
                                <td style="width: 16px;min-width:16px;max-width:16px">Ter</td>
