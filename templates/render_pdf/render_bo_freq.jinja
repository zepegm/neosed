                                    {% else %}
                                    <td class="center gray" style="font-size:10px;">{{professor['qtd_aulas_semanais'][dia]}}</td>
                                    {% endif %}
                                {% else %}
                                    {% if dia == 'sex' %}
                                    <td class="gray" style="border-right: 2px solid black;"></td>
                                    {% else %}
                                    <td class="gray"></td>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
      
