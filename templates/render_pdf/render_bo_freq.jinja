                        {% endfor %}

                        <!-- Colocar o total geral -->
                        <tr style="font-size:7px;" class="gray center">
                            <td style="height: 16px;border-right: 2px solid black;" colspan="2" class="gray"></td>
                            <td>Seg</td><td>Ter</td><td>Qua</td><td>Qui</td><td style="border-right: 2px solid black;">Sex</td><td>Sáb</td><td>Dom</td>
