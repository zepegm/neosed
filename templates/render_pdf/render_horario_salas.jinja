<html>
    <head>
        <title>Rendereziação PDF</title>
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            .pagina {
                height: 730px;
                width: 1064px;
                /*border-width: 2px;
                border-style: solid;*/
                
                color: black;
                /*padding-top: 27px;*/
                margin-left: -7px;
                background-color: white;
            }

            .pagina:first-child {
                margin-top: -7px;
            }

            .paginas_cont {
                width: 729px;
                height: 1057px;
                border-width: 2px;
                border-style: solid;
                margin-top: 30px;
                margin-left: 22px;              
            }

            .tb-principal {
                width: 100%;
                height: 100%;
                border-collapse: collapse;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 19px;
                border: 4px solid black;
                table-layout: fixed;
            }

            .tb-principal th {
                border: 1px solid black;
                text-align: center;
                padding: 8px;
                font-family: Arial, Helvetica, sans-serif;
            }

            .tb-principal td {
                background-color: white;
                border: 1px solid black;
                text-align: center;
                /*padding: 3px;*/
                font-family: Arial, Helvetica, sans-serif;
            }        

            .vertical-text {
                writing-mode: vertical-rl; /* or vertical-lr */
                font-size: 25px !important;
                font-weight: bold;
                transform: rotate(180deg);
            }

            .gray {
                background-color: #e4e4e4 !important;
            }

            .d-2 {
                background-color: rgb(255, 242, 204) !important;    
            }

            .yellow {
                background-color: rgb(255, 242, 204) !important;
            }

            .d-5 {
                background-color: rgb(204, 255, 204) !important;
            }

            .first-line {
                border-top: 4px solid black !important;
            }

            .blue {
                color:white;
                background-color: #0070C0 !important;
                font-weight: bold;
            }

            .titulo {
                font-family:'BebasKai', sans-serif !important;
                font-size: 35px;
                font-weight: normal;    
                padding: 4px !important;
            }

            .red {
                color: red;
            }

            .head {
                height: 5px !important;
                padding: 4px !important;
            }

            .foot {
                text-align: left !important;
            }

            .quadrado_1 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: white; /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            .quadrado_2 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: rgb(255, 242, 204); /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            .quadrado_5 {
                width: 10px; /* Largura do quadrado */
                height: 10px; /* Altura do quadrado */
                background-color: rgb(204, 255, 204); /* Cor de fundo do quadrado */
                border: solid 1px black/* Cor da borda do quadrado */;
                display: inline-block;
            }

            /* disciplinas com cores específicas */

            .ELETIVA {
                background-color: rgb(254, 222, 255) !important;
            }

            .TUTORIA {
                background-color: orange !important;
            }

            .CLUBE {
                background-color: rebeccapurple !important;
                color: white;
            }      

            /* professores com cores específicas */
            {% for item in profs %}
            .prof_{{item['cpf_professor']}} {
                background-color: {{item['cor']}} !important;
            }
            {% endfor %}

        </style>
    </head>
    <body>
        {% set cont = namespace(value=0) %}

        {% for item in turmas %}
        <div class="pagina">
            <table class="tb-principal">

                <thead>
                    <tr>
                        <th class="titulo" colspan="6" style="border-bottom: 2px solid black;"><span>Horário Semanal</span> - <span class="red">{{item['nome_turma']}}</span> - {{item['descricao']}}</th>
                    </tr>
                    <tr>
                        <th class="gray">Horário</th>
                        <th class="gray">Segunda</th>
                        <th class="gray">Terça</th>
                        <th class="gray">Quarta</th>
                        <th class="gray">Quita</th>
                        <th class="gray">Sexta</th>
                    </tr>
                </thead>


                <tbody>
                    {% for item in horario %}
                        <tr>
                            <td class="gray">{{item['horario']}}</td>
                            {% for n in range(2, 7) %}
                                <td class="prof_{{grade[n][cont.value]['cpf_professor']}} {{grade[n][cont.value]['abv']}}">{{grade[n][cont.value]['abv']}} {{grade[n][cont.value]['nome']}}</td>
                            {% endfor %}
                            {% set cont.value = cont.value + turmas|length %}
                        </tr>

                        {% if item['intervalo'] %}
                        <tr>
                            <td class="blue">{{item['intervalo']}}</td>
                            <td colspan="5" class="blue">INTERVALO</td>
                        </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            
            </table>
        </div>
        {% set cont.value = loop.index %}
        {% endfor %}
    </body>
</htmL>