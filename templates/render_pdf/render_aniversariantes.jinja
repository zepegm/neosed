<html>
    <head>
        <title>Rendereziação PDF</title>
        <link href="{{ url_for('static', filename='stylesheets/print-default.css') }}" rel="stylesheet">
        <style>

            @font-face {
                font-family:bebaskai;
                font-style:normal;
                font-weight:400;
                src:local('BebasKai'),
                url({{ url_for('static', filename='fonts/BebasKai-Regular.woff') }}) format('woff')
            }

            .pagina {
                width: 729px;
                height: 1050px;
                border-width: 2px;
                border-style: solid;
                padding:10px;
                
                color: black;
                /*padding-top: 27px;*/
                margin-left: -7px;
                background-color: white;
            }

            .tb-principal {
                width: 100%;
                border-collapse: collapse;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 14px;
                border: 4px solid black;
                border:solid 2px black;
            }

            .tb-principal td, th {
                border: solid 1px black;
                text-align: left;
                min-width: 30px;
                height: 28px;
            }

            .titulo {
                font-size: 30px;
                font-weight: bold;
                font-family: Arial, Helvetica, sans-serif;
                text-align: center;
                margin-bottom: -20px;
                color: rgb(134, 0, 0);
            }

            .subtitulo {
                background-color: rgb(192, 192, 192);
                border-bottom: 2px solid black;
            }

            .subtitulo_text {
                font-family: Arial, Helvetica, sans-serif;
                text-align: center;
                font-weight: bold;
                font-size: 30px;
                margin-bottom: 15px;
            }

            .text-center {
                text-align: center !important;
                padding-left: 0 !important;
            }          

            {% for mes in lista %}{% if mes['lista']|length > 0 %}.{{mes['cor']['class']}} {
                background-color: {{mes['cor']['cor']}};
            }{% endif %}
            
            {% endfor %}

        </style>
    </head>
    <body>

        <div id="loading">
            <div class="loader"></div>
            <p id="progresso-texto">Preparando PDF...</p>
            <!-- <div id="barra-container">
            <div id="barra"></div> -->
            </div>    
        </div>

        <button class="btn no-print" onclick="window.print()">Imprimir</button>

        <div class="pagina">
            <p class="titulo">EE MAJOR HERMÓGENES</p>
            <p class="subtitulo_text">Lista de Aniversariantes de <span style="color:rgb(0, 103, 163);">{{year}}</span></p>
            <table class="tb-principal table table-bordered">
                <thead class="table-warning">
                    <tr>
                        <th style="padding-left: 10px;" class="subtitulo">Nome</th>
                        <th class="subtitulo text-center">Mês</th>
                        <th class="subtitulo text-center">Nascimento</th>
                    </tr>
                </thead>            
                <tbody>
                    {% for item in lista %}
                    {% if item['lista']|length > 0 %}
                        {% for pessoa in item['lista'] %}
                        <tr class="{{item['cor']['class']}}">
                            <td style="padding-left: 10px;">{{pessoa['nome']}}</td>
                            <td style="text-align: center;">{{item['mes']}}</td>
                            <td style="text-align: center;">{{pessoa['nascimento']}}</td>
                        </tr>
                        {% endfor %}
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <script src="{{ url_for('static', filename='js/print-default.js') }}"></script> 
    </body>
</htmL>